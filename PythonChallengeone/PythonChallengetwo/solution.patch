+class HolidayDiff:
+    """Categorized result of comparing two :class:`HolidayBase` instances.
+
+    Produced by :func:`holidays.calendar_diff`.  Each attribute holds the
+    corresponding list of change-tuples.
+    """
+
+    __slots__ = ("added", "removed", "shifted", "renamed")
+
+    def __init__(
+        self,
+        added: list[tuple[date, str]],
+        removed: list[tuple[date, str]],
+        shifted: list[tuple[date, str, date, str]],
+        renamed: list[tuple[date, str, str]],
+    ) -> None:
+        self.added: list[tuple[date, str]] = list(added)
+        self.removed: list[tuple[date, str]] = list(removed)
+        self.shifted: list[tuple[date, str, date, str]] = list(shifted)
+        self.renamed: list[tuple[date, str, str]] = list(renamed)
+
+    def __eq__(self, other: object) -> bool:
+        if not isinstance(other, HolidayDiff):
+            return NotImplemented
+        return (
+            self.added == other.added
+            and self.removed == other.removed
+            and self.shifted == other.shifted
+            and self.renamed == other.renamed
+        )
+
+    def __len__(self) -> int:
+        return len(self.added) + len(self.removed) + len(self.shifted) + len(self.renamed)
+
+    def __bool__(self) -> bool:
+        return bool(self.added or self.removed or self.shifted or self.renamed)
+
+    def __repr__(self) -> str:
+        return (
+            f"HolidayDiff("
+            f"added={len(self.added)}, "
+            f"removed={len(self.removed)}, "
+            f"shifted={len(self.shifted)}, "
+            f"renamed={len(self.renamed)})"
+        )
+
+    @property
+    def is_empty(self) -> bool:
+        return not bool(self)
+
+    def filter(
+        self,
+        start: date | None = None,
+        end: date | None = None,
+    ) -> "HolidayDiff":
+        """Return a new :class:`HolidayDiff` restricted to the given date range.
+
+        Both *start* and *end* are inclusive.  ``None`` means unbounded.
+        For *shifted* entries the old date is used as the filter key.
+        """
+        def _in_range(d: date) -> bool:
+            return (start is None or d >= start) and (end is None or d <= end)
+        return HolidayDiff(
+            added=[(d, n) for d, n in self.added if _in_range(d)],
+            removed=[(d, n) for d, n in self.removed if _in_range(d)],
+            shifted=[(d1, n1, d2, n2) for d1, n1, d2, n2 in self.shifted if _in_range(d1)],
+            renamed=[(d, old, new) for d, old, new in self.renamed if _in_range(d)],
+        )
