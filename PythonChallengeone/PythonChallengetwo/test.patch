+#!/usr/bin/env bash
+set -euo pipefail
+
+OUTPUT_PATH=""
+MODE=""
+
+while [[ $# -gt 0 ]]; do
+  case "$1" in
+    --output_path)
+      OUTPUT_PATH="$2"
+      shift 2
+      ;;
+    base|new)
+      MODE="$1"
+      shift
+      ;;
+    *)
+      echo "Usage: $0 --output_path <path> [base|new]" >&2
+      exit 1
+      ;;
+  esac
+done
+
+if [ -z "$MODE" ]; then
+  echo "Usage: $0 --output_path <path> [base|new]" >&2
+  exit 1
+fi
+
+JUNIT_ARGS=()
+if [ -n "$OUTPUT_PATH" ]; then
+  JUNIT_ARGS=(--junit-xml="$OUTPUT_PATH")
+fi
+
+if [ "$MODE" = "base" ]; then
+  python -m pytest \
+    tests/test_holiday_base.py \
+    tests/test_utils.py \
+    tests/test_registry.py \
+    tests/test_helpers.py \
+    tests/test_package.py \
+    -k "not test_pickle_localized_entity and not test_localized_countries and not test_localized_financial" \
+    --override-ini="addopts=" \
+    -v \
+    "${JUNIT_ARGS[@]}"
+elif [ "$MODE" = "new" ]; then
+  python -m pytest \
+    tests/test_calendar_diff.py \
+    --override-ini="addopts=" \
+    -v \
+    "${JUNIT_ARGS[@]}"
+else
+  echo "Usage: $0 --output_path <path> [base|new]" >&2
+  exit 1
+fi
