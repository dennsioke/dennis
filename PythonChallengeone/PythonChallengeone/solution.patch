+def _check_extra_config_fields(cfg: Config) -> list[str]:
+    """Validate EXTRA_SPECS and EXTRA_DOMAIN_SUBSTITUTIONS in *cfg*.
+
+    Performs lightweight sanity checks and returns a list of human-readable
+    issue messages.  Validation is advisory: the returned messages are emitted
+    as :mod:`warnings` by :func:`import_config` to help users catch
+    misconfiguration early, but they do **not** prevent the config from
+    being used.
+
+    Checks performed on ``EXTRA_SPECS``
+    ------------------------------------
+    * Every key must be a non-empty string representing a bare domain (no
+      ``http://`` scheme prefix, no ``/`` path separator, no ``?`` or ``#``).
+    * Every value must be a :class:`~promnesia.cannon.Spec` instance.
+
+    Checks performed on ``EXTRA_DOMAIN_SUBSTITUTIONS``
+    ---------------------------------------------------
+    * Every element must be a 2-tuple of strings.
+    * The prefix (first element) must be a non-empty string.
+
+    Parameters
+    ----------
+    cfg : Config
+        The fully-constructed :class:`Config` to inspect.
+
+    Returns
+    -------
+    list[str]
+        One message per problem found; empty list means no issues detected.
+    """
+    issues: list[str] = []
+
+    # --- EXTRA_SPECS validation ---
+    raw_specs: dict = getattr(cfg, 'EXTRA_SPECS', None) or {}
+    for domain, spec_val in raw_specs.items():
+        if not isinstance(domain, str) or not domain:
+            issues.append(
+                f'EXTRA_SPECS: domain key {domain!r} must be a non-empty string'
+            )
+            continue
+        if domain.startswith(('http://', 'https://')):
+            issues.append(
+                f'EXTRA_SPECS: key {domain!r} includes a URL scheme; '
+                'use the bare domain name only (e.g. "wiki.corp.com")'
+            )
+        elif '/' in domain or '?' in domain or '#' in domain:
+            issues.append(
+                f'EXTRA_SPECS: key {domain!r} looks like a URL (contains a path, '
+                'query, or fragment); expected a bare domain name'
+            )
+        if not isinstance(spec_val, Spec):
+            issues.append(
+                f'EXTRA_SPECS[{domain!r}]: value must be a promnesia.cannon.Spec '
+                f'instance, got {type(spec_val).__name__!r}'
+            )
+
+    # --- EXTRA_DOMAIN_SUBSTITUTIONS validation ---
+    raw_subs: list = getattr(cfg, 'EXTRA_DOMAIN_SUBSTITUTIONS', None) or []
+    for idx, item in enumerate(raw_subs):
+        if not (isinstance(item, tuple) and len(item) == 2):
+            issues.append(
+                f'EXTRA_DOMAIN_SUBSTITUTIONS[{idx}]: each entry must be a '
+                f'(str, str) 2-tuple, got {item!r}'
+            )
+            continue
+        prefix, replacement = item
+        if not isinstance(prefix, str) or not isinstance(replacement, str):
+            issues.append(
+                f'EXTRA_DOMAIN_SUBSTITUTIONS[{idx}]: both tuple elements must be '
+                f'strings; got ({type(prefix).__name__!r}, {type(replacement).__name__!r})'
+            )
+        elif not prefix:
+            issues.append(
+                f'EXTRA_DOMAIN_SUBSTITUTIONS[{idx}]: prefix (first element) '
+                'must be a non-empty string'
+            )
+
+    return issues
+
+
