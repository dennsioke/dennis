+# ---------------------------------------------------------------------------
+# Runtime config integration - lazy import helpers
+#
+# cannon.py is a foundational module that is imported by common.py, which is in
+# turn imported by config.py.  Importing config.py at module level here would
+# create a circular dependency:
+#
+#   cannon.py (module level) -> config.py -> common.py -> cannon.py
+#
+# All config lookups therefore use deferred local imports inside the functions
+# that need them.  This is the established pattern in this codebase; see also
+# extract.py, which uses the same technique for the FILTERS list.
+# ---------------------------------------------------------------------------
+
+
+def _get_config() -> 'Any | None':
+    """Return the active promnesia Config instance, or None if not loaded.
+
+    Uses a deferred local import to avoid the circular import that would arise
+    if config were imported at cannon.py module level::
+
+        cannon.py -> config.py -> common.py -> cannon.py
+
+    The function is safe to call from anywhere in this module.  It reflects the
+    live singleton managed by promnesia.config, so there is no risk of stale
+    data from module-level caching; every call re-checks the current state.
+
+    Returns
+    -------
+    Config | None
+        The active ``Config`` instance, or *None* if config has not been loaded
+        or if the relative import fails (e.g. when cannon is used standalone).
+    """
+    try:
+        from . import config as _config_module  # noqa: PLC0415
+    except ImportError:
+        # cannon.py may be executed as a standalone script via __main__; in
+        # that case the relative import will fail and config is unavailable.
+        return None
+    if not _config_module.has():
+        return None
+    return _config_module.get()
+
+
+def _extra_domain_substitutions() -> list[tuple[str, str]]:
+    """Return user-defined domain prefix substitutions from the active config.
+
+    Each element is a ``(prefix, replacement)`` pair matching the format of the
+    built-in ``dom_subst`` list.  When ``canonify_domain`` encounters a domain
+    that starts with *prefix* it replaces that prefix with *replacement* and
+    stops checking further custom substitutions (first-match semantics,
+    identical to the built-in list).
+
+    Custom substitutions are evaluated **before** the built-in ``dom_subst``
+    entries so that private or organisational domains can be normalised without
+    requiring modifications to this library.  If a custom substitution and a
+    built-in one both match the same domain prefix, the custom one wins because
+    it is checked first.
+
+    Returns
+    -------
+    list[tuple[str, str]]
+        The ``EXTRA_DOMAIN_SUBSTITUTIONS`` list from the active config, or an
+        empty list if no config is loaded, the field is absent, or the list is
+        empty.
+    """
+    cfg = _get_config()
+    if cfg is None:
+        return []
+    try:
+        extra = cfg.EXTRA_DOMAIN_SUBSTITUTIONS
+    except AttributeError:
+        # Config object predates this feature - treat as if field is empty.
+        return []
+    return list(extra) if extra else []
+
+
+def _extra_spec_for_domain(dom: str) -> 'Spec | None':
+    """Look up a user-defined canonification spec for *dom* in the active config.
+
+    Applies the same suffix-based domain matching used by :func:`get_spec` for
+    built-in specs, so a spec registered for ``'corp.com'`` also applies to
+    ``'wiki.corp.com'``.  A more-specific entry (``'wiki.corp.com'``) takes
+    precedence over a less-specific one (``'corp.com'``).
+
+    This function is called **after** :func:`canonify_domain` has already
+    applied domain substitutions, so *dom* is receive in its canonical alias
+    form.  For example, if the user configured ``('m.intranet.', 'intranet.')``
+    as a substitution and ``{'intranet.corp': Spec(...)}`` as a custom spec,
+    the URL ``m.intranet.corp/...`` will have its domain remapped to
+    ``intranet.corp`` before this function is called, and the spec will match.
+
+    A custom spec **completely replaces** the built-in spec for the same domain;
+    it does not merge or inherit from it.  The global ``default_qkeep``
+    parameters (``id``, ``t``, ``p``) remain effective because they are resolved
+    inside :class:`Spec` itself, regardless of which spec is selected.
+
+    Parameters
+    ----------
+    dom : str
+        The domain string to look up, already in substituted canonical form.
+
+    Returns
+    -------
+    Spec | None
+        The custom ``Spec`` if an ``EXTRA_SPECS`` entry matches *dom*, or
+        *None* if no config is active, ``EXTRA_SPECS`` is empty, or no entry
+        matches *dom*.
+    """
+    cfg = _get_config()
+    if cfg is None:
+        return None
+    try:
+        extra_specs: dict[str, Spec] = cfg.EXTRA_SPECS
+    except AttributeError:
+        # Config object predates this feature - treat as if field is empty.
+        return None
+    if not extra_specs:
+        return None
+
+    # Mirror the suffix-matching logic used by get_spec() for built-in specs.
+    # Build domain suffixes from least-specific to most-specific (e.g.
+    # 'com' -> 'corp.com' -> 'wiki.corp.com') and return the first match so
+    # that we find the most-specific entry available.
+    parts = dom.split('.')
+    cur: str | None = None
+    for part in reversed(parts):
+        if cur is None:
+            cur = part
+        else:
+            cur = f'{part}.{cur}'
+        sp = extra_specs.get(cur)
+        if sp is not None:
+            return sp
+
+    return None
+
+
+def get_effective_domain_substitutions() -> list[tuple[str, str]]:
+    """Return the complete ordered list of domain prefix substitutions.
+
+    Combines user-defined substitutions from the active config with the
+    built-in ``dom_subst`` list.  Custom entries come first so that they take
+    priority over built-in ones for the same prefix.
+
+    This is the substitution sequence that :func:`canonify_domain` applies at
+    runtime.  It is exposed primarily for debugging and inspection; callers
+    should generally use :func:`canonify_domain` or :func:`canonify` directly
+    rather than applying substitutions manually.
+
+    Returns
+    -------
+    list[tuple[str, str]]
+        Ordered ``(prefix, replacement)`` pairs with custom entries preceding
+        built-in entries.
+    """
+    extra = _extra_domain_substitutions()
+    return [*extra, *dom_subst]
+
+
+def get_effective_specs() -> dict[str, Spec]:
+    """Return a snapshot of all domain-to-spec mappings, custom and built-in.
+
+    Custom specs from the active config ``EXTRA_SPECS`` take priority over
+    built-in ones: where both define a spec for the same domain key, the
+    custom entry shadows the built-in one in the returned dict.
+
+    Note that the dict alone does not fully represent the lookup semantics used
+    by :func:`get_spec`, because matching is suffix-based (a spec for
+    ``'corp.com'`` also applies to ``'wiki.corp.com'``).  The returned dict
+    only reflects exact-key matches; use :func:`get_spec` for real lookups.
+
+    The snapshot reflects the state at call time and is **not** live; it will
+    not change if the config is subsequently modified.
+
+    Returns
+    -------
+    dict[str, Spec]
+        Merged spec mapping with custom entries taking priority over built-ins.
+    """
+    cfg = _get_config()
+    extra: dict[str, Spec] = {}
+    if cfg is not None:
+        try:
+            extra = dict(cfg.EXTRA_SPECS or {})
+        except AttributeError:
+            pass
+    # Built-in specs form the baseline; custom entries shadow them where keys overlap.
+    return {**specs, **extra}
+
+
