+# deferred import to avoid circular: cannon -> config -> common -> cannon (same pattern as extract.py filters())
+def _get_config() -> 'Any | None':
+    try:
+        from . import config as _config_module  # noqa: PLC0415
+    except ImportError:
+        return None
+    if not _config_module.has():
+        return None
+    return _config_module.get()
+
+
+def _extra_domain_substitutions() -> list[tuple[str, str]]:
+    cfg = _get_config()
+    if cfg is None:
+        return []
+    return list(cfg.EXTRA_DOMAIN_SUBSTITUTIONS) if cfg.EXTRA_DOMAIN_SUBSTITUTIONS else []
+
+
+def _extra_spec_for_domain(dom: str) -> 'Spec | None':
+    cfg = _get_config()
+    if cfg is None:
+        return None
+    extra_specs: dict[str, Spec] = cfg.EXTRA_SPECS
+    if not extra_specs:
+        return None
+    # same suffix-matching as get_spec()
+    parts = dom.split('.')
+    cur: str | None = None
+    for part in reversed(parts):
+        if cur is None:
+            cur = part
+        else:
+            cur = f'{part}.{cur}'
+        sp = extra_specs.get(cur)
+        if sp is not None:
+            return sp
+    return None
+
+
