diff --git a/src/runtime/hall-task-dependency.ts b/src/runtime/hall-task-dependency.ts
new file mode 100644
index 0000000..03f1347
--- /dev/null
+++ b/src/runtime/hall-task-dependency.ts
@@ -0,0 +1,314 @@
+import {
+  CollaborationHallStoreValidationError,
+  getHallTaskCard,
+  loadCollaborationTaskCardStore,
+  saveCollaborationTaskCardStore,
+} from "./collaboration-hall-store";
+import type { CollaborationTaskCardStoreSnapshot, HallTaskCard } from "../types";
+
+export interface AddHallTaskDependencyInput {
+  taskCardId: string;
+  dependsOnTaskCardId: string;
+}
+
+export interface RemoveHallTaskDependencyInput {
+  taskCardId: string;
+  dependsOnTaskCardId: string;
+}
+
+export interface DependencyMutationResult {
+  path: string;
+  taskCard: HallTaskCard;
+}
+
+export async function addHallTaskDependency(
+  input: AddHallTaskDependencyInput,
+): Promise<DependencyMutationResult> {
+  const { taskCardId, dependsOnTaskCardId } = input;
+
+  if (taskCardId === dependsOnTaskCardId) {
+    throw new CollaborationHallStoreValidationError(
+      `task card '${taskCardId}' cannot depend on itself.`,
+      ["dependsOnTaskCardId"],
+      400,
+    );
+  }
+
+  const store = await loadCollaborationTaskCardStore();
+  const card = getHallTaskCard(store, taskCardId);
+  if (!card) {
+    throw new CollaborationHallStoreValidationError(
+      `task card '${taskCardId}' was not found.`,
+      ["taskCardId"],
+      404,
+    );
+  }
+
+  const depCard = getHallTaskCard(store, dependsOnTaskCardId);
+  if (!depCard) {
+    throw new CollaborationHallStoreValidationError(
+      `dependency target card '${dependsOnTaskCardId}' does not exist.`,
+      ["dependsOnTaskCardId"],
+      400,
+    );
+  }
+
+  if (card.dependsOn.includes(dependsOnTaskCardId)) {
+    return { path: "", taskCard: card };
+  }
+
+  const candidateDeps = [...card.dependsOn, dependsOnTaskCardId];
+  const activeCards = store.taskCards.filter((c) => !c.archivedAt);
+  const adjacency = buildAdjacencyMap(activeCards);
+  adjacency.set(taskCardId, candidateDeps.filter((d) => activeCards.some((c) => c.taskCardId === d)));
+
+  if (detectCycle(adjacency, activeCards.map((c) => c.taskCardId))) {
+    throw new CollaborationHallStoreValidationError(
+      `adding dependency '${dependsOnTaskCardId}' to '${taskCardId}' would create a cycle.`,
+      ["dependsOnTaskCardId"],
+      400,
+    );
+  }
+
+  card.dependsOn = candidateDeps;
+  card.updatedAt = new Date().toISOString();
+  store.updatedAt = card.updatedAt;
+  const path = await saveCollaborationTaskCardStore(store);
+  return { path, taskCard: card };
+}
+
+export async function removeHallTaskDependency(
+  input: RemoveHallTaskDependencyInput,
+): Promise<DependencyMutationResult> {
+  const { taskCardId, dependsOnTaskCardId } = input;
+  const store = await loadCollaborationTaskCardStore();
+  const card = getHallTaskCard(store, taskCardId);
+  if (!card) {
+    throw new CollaborationHallStoreValidationError(
+      `task card '${taskCardId}' was not found.`,
+      ["taskCardId"],
+      404,
+    );
+  }
+
+  card.dependsOn = card.dependsOn.filter((d) => d !== dependsOnTaskCardId);
+  card.updatedAt = new Date().toISOString();
+  store.updatedAt = card.updatedAt;
+  const path = await saveCollaborationTaskCardStore(store);
+  return { path, taskCard: card };
+}
+
+export async function cascadeBlockedState(rootCardId: string): Promise<string[]> {
+  const store = await loadCollaborationTaskCardStore();
+  const rootCard = getHallTaskCard(store, rootCardId);
+  if (!rootCard) return [];
+
+  const downstream = collectTransitiveDependents(store, rootCardId);
+  const blockerTag = `blocked-by:${rootCardId}`;
+  const cascaded: string[] = [];
+
+  for (const cardId of downstream) {
+    const card = getHallTaskCard(store, cardId);
+    if (!card) continue;
+    if (card.stage === "completed" || card.archivedAt) continue;
+
+    let mutated = false;
+    if (card.stage !== "blocked") {
+      card.stage = "blocked";
+      mutated = true;
+    }
+    if (!card.blockers.includes(blockerTag)) {
+      card.blockers = [...card.blockers, blockerTag];
+      mutated = true;
+    }
+    if (mutated) {
+      card.updatedAt = new Date().toISOString();
+      cascaded.push(cardId);
+    }
+  }
+
+  if (cascaded.length > 0) {
+    store.updatedAt = new Date().toISOString();
+    await saveCollaborationTaskCardStore(store);
+  }
+
+  return cascaded;
+}
+
+export async function cascadeUnblockState(resolvedCardId: string): Promise<string[]> {
+  const store = await loadCollaborationTaskCardStore();
+  const blockerTag = `blocked-by:${resolvedCardId}`;
+  const unblocked: string[] = [];
+
+  for (const card of store.taskCards) {
+    const hasBlockerTag = card.blockers.includes(blockerTag);
+    const dependsOnResolved = card.dependsOn.includes(resolvedCardId);
+
+    if (!hasBlockerTag && !dependsOnResolved) continue;
+
+    if (hasBlockerTag) {
+      card.blockers = card.blockers.filter((b) => b !== blockerTag);
+      card.updatedAt = new Date().toISOString();
+    }
+
+    if (card.stage !== "blocked") continue;
+
+    const remainingDependencyBlockers = card.blockers.filter((b) => b.startsWith("blocked-by:"));
+    if (remainingDependencyBlockers.length === 0) {
+      const allDepsCompleted = card.dependsOn.every((depId) => {
+        const depCard = getHallTaskCard(store, depId);
+        return !depCard || depCard.stage === "completed" || depCard.archivedAt;
+      });
+      if (allDepsCompleted) {
+        card.stage = "discussion";
+        if (!hasBlockerTag) {
+          card.updatedAt = new Date().toISOString();
+        }
+        unblocked.push(card.taskCardId);
+      }
+    }
+  }
+
+  store.updatedAt = new Date().toISOString();
+  await saveCollaborationTaskCardStore(store);
+  return unblocked;
+}
+
+export function topologicalOrder(store: CollaborationTaskCardStoreSnapshot): string[] {
+  const active = store.taskCards.filter((c) => !c.archivedAt && c.stage !== "completed");
+
+  const activeIds = new Set(active.map((c) => c.taskCardId));
+  const cardMap = new Map(active.map((c) => [c.taskCardId, c]));
+  const inDegree = new Map<string, number>();
+  const adjacency = new Map<string, string[]>();
+
+  for (const card of active) {
+    inDegree.set(card.taskCardId, 0);
+    adjacency.set(card.taskCardId, []);
+  }
+
+  for (const card of active) {
+    for (const depId of card.dependsOn) {
+      if (!activeIds.has(depId)) continue;
+      adjacency.get(depId)!.push(card.taskCardId);
+      inDegree.set(card.taskCardId, (inDegree.get(card.taskCardId) ?? 0) + 1);
+    }
+  }
+
+  const queue: string[] = [];
+  const tierCompare = (a: string, b: string): number => {
+    const cardA = cardMap.get(a)!;
+    const cardB = cardMap.get(b)!;
+    const timeDiff = Date.parse(cardA.createdAt) - Date.parse(cardB.createdAt);
+    if (timeDiff !== 0) return timeDiff;
+    return a.localeCompare(b);
+  };
+
+  const zeroInDegree = active
+    .filter((c) => (inDegree.get(c.taskCardId) ?? 0) === 0)
+    .map((c) => c.taskCardId)
+    .sort(tierCompare);
+
+  for (const id of zeroInDegree) {
+    queue.push(id);
+  }
+
+  const result: string[] = [];
+  let head = 0;
+
+  while (head < queue.length) {
+    const batchStart = head;
+    const batchEnd = queue.length;
+    const batch = queue.slice(batchStart, batchEnd).sort(tierCompare);
+    for (let i = batchStart; i < batchEnd; i++) {
+      queue[i] = batch[i - batchStart];
+    }
+
+    for (let i = batchStart; i < batchEnd; i++) {
+      const current = queue[i];
+      result.push(current);
+      for (const neighbor of adjacency.get(current) ?? []) {
+        const deg = (inDegree.get(neighbor) ?? 1) - 1;
+        inDegree.set(neighbor, deg);
+        if (deg === 0) {
+          queue.push(neighbor);
+        }
+      }
+    }
+    head = batchEnd;
+  }
+
+  return result;
+}
+
+export function impactAnalysis(
+  store: CollaborationTaskCardStoreSnapshot,
+  taskCardId: string,
+): Set<string> {
+  return collectTransitiveDependents(store, taskCardId);
+}
+
+function collectTransitiveDependents(
+  store: CollaborationTaskCardStoreSnapshot,
+  rootId: string,
+): Set<string> {
+  const reverseAdj = new Map<string, string[]>();
+  for (const card of store.taskCards) {
+    for (const depId of card.dependsOn) {
+      let list = reverseAdj.get(depId);
+      if (!list) {
+        list = [];
+        reverseAdj.set(depId, list);
+      }
+      list.push(card.taskCardId);
+    }
+  }
+
+  const visited = new Set<string>();
+  const stack = [rootId];
+  while (stack.length > 0) {
+    const current = stack.pop()!;
+    for (const child of reverseAdj.get(current) ?? []) {
+      if (!visited.has(child)) {
+        visited.add(child);
+        stack.push(child);
+      }
+    }
+  }
+
+  return visited;
+}
+
+function buildAdjacencyMap(cards: HallTaskCard[]): Map<string, string[]> {
+  const adj = new Map<string, string[]>();
+  for (const card of cards) {
+    adj.set(card.taskCardId, [...card.dependsOn]);
+  }
+  return adj;
+}
+
+function detectCycle(adjacency: Map<string, string[]>, nodeIds: string[]): boolean {
+  const WHITE = 0;
+  const GRAY = 1;
+  const BLACK = 2;
+  const color = new Map<string, number>();
+  for (const id of nodeIds) {
+    color.set(id, WHITE);
+  }
+
+  const dfs = (node: string): boolean => {
+    color.set(node, GRAY);
+    for (const neighbor of adjacency.get(node) ?? []) {
+      const c = color.get(neighbor);
+      if (c === GRAY) return true;
+      if (c === WHITE && dfs(neighbor)) return true;
+    }
+    color.set(node, BLACK);
+    return false;
+  };
+
+  for (const id of nodeIds) {
+    if (color.get(id) === WHITE && dfs(id)) return true;
+  }
+  return false;
+}
