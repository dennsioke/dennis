+#!/usr/bin/env bash
+set -euo pipefail
+
+MODE="${1:-new}"
+
+if [ "$MODE" = "base" ]; then
+  OPENCLAW_RUNTIME_DIR="$(mktemp -d)" node --import tsx --test --test-concurrency=1 \
+    test/hall-execution-lock.test.ts \
+    test/hall-role-resolver.test.ts \
+    test/hall-mention-router.test.ts \
+    test/commander-ordering.test.ts \
+    test/hall-handoff.test.ts \
+    test/collaboration-hall-store.test.ts
+elif [ "$MODE" = "new" ]; then
+  OPENCLAW_RUNTIME_DIR="$(mktemp -d)" node --import tsx --test --test-concurrency=1 \
+    test/hall-task-dependency.test.ts
+else
+  echo "Usage: $0 [base|new]" >&2
+  exit 1
+fi
