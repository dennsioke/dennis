+
+    store = await loadCollaborationTaskCardStore();
+    child = getHallTaskCard(store, childId)!;
+    assert.equal(child.stage, "blocked");
+    assert(!child.blockers.includes(`blocked-by:${aId}`));
+    assert(child.blockers.includes(`blocked-by:${bId}`));
