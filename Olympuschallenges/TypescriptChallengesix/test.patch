diff --git a/__tests__/cancellation.test.ts b/__tests__/cancellation.test.ts
new file mode 100644
index 0000000..d754386
--- /dev/null
+++ b/__tests__/cancellation.test.ts
@@ -0,0 +1,655 @@
+import { expect, it, describe } from "vitest"
+import { RpcSession, RpcTarget, RpcStub, RpcTransport } from "../src/index.js"
+import { Counter } from "./test-util.js"
+
+// Test Assumptions:
+// - Symbol.dispose is the standard JS disposal protocol; the library polyfills it in core.ts
+// - dup() creates a second stub sharing the same underlying import (public API on stubs)
+// - These are existing public APIs in the capnweb library, used here to exercise
+//   documented cancellation semantics around disposal and deduplication.
+
+class TestTransport implements RpcTransport {
+  constructor(public name: string, private partner?: TestTransport) {
+    if (partner) {
+      partner.partner = this;
+    }
+  }
+
+  private queue: string[] = [];
+  private waiter?: () => void;
+  private aborter?: (err: any) => void;
+  public sentLog: string[] = [];
+
+  async send(message: string): Promise<void> {
+    message = message.replaceAll("$remove$", "");
+    this.sentLog.push(message);
+    this.partner!.queue.push(message);
+    if (this.partner!.waiter) {
+      this.partner!.waiter();
+      this.partner!.waiter = undefined;
+      this.partner!.aborter = undefined;
+    }
+  }
+
+  async receive(): Promise<string> {
+    while (this.queue.length == 0) {
+      await new Promise<void>((resolve, reject) => {
+        this.waiter = resolve;
+        this.aborter = reject;
+      });
+    }
+    return this.queue.shift()!;
+  }
+
+  forceReceiveError(error: any) {
+    this.aborter!(error);
+  }
+}
+
+async function pumpMicrotasks() {
+  for (let i = 0; i < 16; i++) {
+    await Promise.resolve();
+  }
+}
+
+class Harness<T extends RpcTarget> {
+  clientTransport: TestTransport;
+  serverTransport: TestTransport;
+  client: RpcSession<T>;
+  server: RpcSession;
+  stub: RpcStub<T>;
+
+  constructor(target: T) {
+    this.clientTransport = new TestTransport("client");
+    this.serverTransport = new TestTransport("server", this.clientTransport);
+    this.client = new RpcSession<T>(this.clientTransport);
+    this.server = new RpcSession<undefined>(this.serverTransport, target);
+    this.stub = this.client.getRemoteMain();
+  }
+}
+
+class SlowTarget extends RpcTarget {
+  square(i: number) {
+    return i * i;
+  }
+
+  makeCounter(i: number) {
+    return new Counter(i);
+  }
+
+  add(a: number, b: number) {
+    return a + b;
+  }
+
+  identity<T>(x: T): T {
+    return x;
+  }
+
+  generateSequence(length: number): number[] {
+    let result: number[] = [];
+    for (let i = 0; i < length; i++) {
+      result.push(i);
+    }
+    return result;
+  }
+}
+
+describe("RPC cancellation", () => {
+
+  it("cancel() rejects the promise with AbortError DOMException", async () => {
+    let h = new Harness(new SlowTarget());
+
+    let promise = h.stub.square(5);
+    (promise as any).cancel("test cancellation");
+
+    try {
+      await promise;
+      throw new Error("should have thrown");
+    } catch (err: any) {
+      expect(err).toBeInstanceOf(DOMException);
+      expect(err.name).toBe("AbortError");
+      expect(err.message).toBe("test cancellation");
+    }
+
+    await pumpMicrotasks();
+  });
+
+  it("cancel() without reason uses a default AbortError message", async () => {
+    let h = new Harness(new SlowTarget());
+
+    let promise = h.stub.square(7);
+    (promise as any).cancel();
+
+    try {
+      await promise;
+      throw new Error("should have thrown");
+    } catch (err: any) {
+      expect(err).toBeInstanceOf(DOMException);
+      expect(err.name).toBe("AbortError");
+      expect(typeof err.message).toBe("string");
+      expect(err.message.length).toBeGreaterThan(0);
+    }
+
+    await pumpMicrotasks();
+  });
+
+  it("cancel sends a cancel protocol message to the peer", async () => {
+    let h = new Harness(new SlowTarget());
+
+    let promise = h.stub.add(10, 20);
+    await pumpMicrotasks();
+
+    h.clientTransport.sentLog.length = 0;
+
+    let cancelResult = (promise as any).cancel("peer cancel test");
+    expect(cancelResult).toBeUndefined();
+
+    await pumpMicrotasks();
+
+    let cancelMessages = h.clientTransport.sentLog
+      .map(m => JSON.parse(m))
+      .filter((m: any) => Array.isArray(m) && m[0] === "cancel");
+
+    expect(cancelMessages.length).toBe(1);
+    expect(cancelMessages[0][0]).toBe("cancel");
+    expect(typeof cancelMessages[0][1]).toBe("number");
+
+    await pumpMicrotasks();
+  });
+
+  it("peer disposes export on receiving cancel message", async () => {
+    let h = new Harness(new SlowTarget());
+
+    let promise = h.stub.add(1, 2);
+    await pumpMicrotasks();
+
+    let exportsBefore = h.server.getStats().exports;
+
+    h.clientTransport.sentLog.length = 0;
+    (promise as any).cancel("dispose test");
+    await pumpMicrotasks();
+
+    let cancelMessages = h.clientTransport.sentLog
+      .map(m => JSON.parse(m))
+      .filter((m: any) => Array.isArray(m) && m[0] === "cancel");
+    expect(cancelMessages.length).toBe(1);
+
+    let exportsAfter = h.server.getStats().exports;
+    expect(exportsAfter).toBeLessThan(exportsBefore);
+
+    await pumpMicrotasks();
+  });
+
+  it("withAbortSignal cancels when signal fires", async () => {
+    let h = new Harness(new SlowTarget());
+    let controller = new AbortController();
+
+    let promise = h.stub.square(3);
+    (promise as any).withAbortSignal(controller.signal);
+
+    controller.abort("signal abort reason");
+
+    try {
+      await promise;
+      throw new Error("should have thrown");
+    } catch (err: any) {
+      expect(err).toBeInstanceOf(DOMException);
+      expect(err.name).toBe("AbortError");
+      expect(err.message).toBe("signal abort reason");
+    }
+
+    await pumpMicrotasks();
+  });
+
+  it("withAbortSignal with pre-aborted signal cancels synchronously", async () => {
+    let h = new Harness(new SlowTarget());
+    let controller = new AbortController();
+    controller.abort("already aborted");
+
+    let promise = h.stub.square(9);
+
+    let rejected = false;
+    let rejection: any = null;
+    promise.then(() => {}, (err: any) => { rejected = true; rejection = err; });
+
+    (promise as any).withAbortSignal(controller.signal);
+
+    // cancel() is invoked synchronously inside withAbortSignal when the signal
+    // is already aborted.  The rejection propagates through the internal promise
+    // chain within a small bounded number of microtasks (not deferred to a
+    // macrotask or setTimeout), proving synchronous initiation.
+    for (let i = 0; i < 4; i++) await Promise.resolve();
+
+    expect(rejected).toBe(true);
+    expect(rejection).toBeInstanceOf(DOMException);
+    expect(rejection.name).toBe("AbortError");
+
+    await pumpMicrotasks();
+
+    let cancelSent = h.clientTransport.sentLog
+      .map(m => JSON.parse(m))
+      .some((m: any) => Array.isArray(m) && m[0] === "cancel");
+
+    expect(cancelSent).toBe(true);
+
+    await pumpMicrotasks();
+  });
+
+  it("pipelined child calls are cancelled when parent is cancelled", async () => {
+    let h = new Harness(new SlowTarget());
+
+    let parentPromise = h.stub.makeCounter(10);
+    let childResult = parentPromise.increment(5);
+
+    await pumpMicrotasks();
+
+    (parentPromise as any).cancel("cascade test");
+
+    try {
+      await childResult;
+      throw new Error("child should have been cancelled");
+    } catch (err: any) {
+      expect(err).toBeInstanceOf(DOMException);
+      expect(err.name).toBe("AbortError");
+      expect(err.message).toBe("cascade test");
+    }
+
+    await pumpMicrotasks();
+  });
+
+  it("deep pipeline chain cascades cancel through all levels", async () => {
+    let h = new Harness(new SlowTarget());
+
+    let level1 = h.stub.makeCounter(0);
+    let level2 = level1.increment(1);
+    let level3 = level1.increment(2);
+
+    await pumpMicrotasks();
+
+    (level1 as any).cancel("deep cascade");
+
+    let errors: DOMException[] = [];
+    for (let p of [level2, level3]) {
+      try {
+        await p;
+        throw new Error("should have thrown");
+      } catch (err: any) {
+        errors.push(err);
+      }
+    }
+
+    expect(errors).toHaveLength(2);
+    for (let err of errors) {
+      expect(err).toBeInstanceOf(DOMException);
+      expect(err.name).toBe("AbortError");
+      expect(err.message).toBe("deep cascade");
+    }
+
+    await pumpMicrotasks();
+  });
+
+  it("multiple stubs sharing import produce exactly one cancel message", async () => {
+    let h = new Harness(new SlowTarget());
+
+    let promise = h.stub.square(4);
+    let dup = (promise as any).dup();
+
+    await pumpMicrotasks();
+    h.clientTransport.sentLog.length = 0;
+
+    (promise as any).cancel("dedup test");
+
+    await pumpMicrotasks();
+
+    let cancelMessages = h.clientTransport.sentLog
+      .map(m => JSON.parse(m))
+      .filter((m: any) => Array.isArray(m) && m[0] === "cancel");
+
+    expect(cancelMessages.length).toBe(1);
+
+    try {
+      (dup as any).cancel("dedup test 2");
+    } catch (_e) {}
+    await pumpMicrotasks();
+
+    let totalCancels = h.clientTransport.sentLog
+      .map(m => JSON.parse(m))
+      .filter((m: any) => Array.isArray(m) && m[0] === "cancel");
+
+    expect(totalCancels.length).toBe(1);
+
+    await pumpMicrotasks();
+  });
+
+  it("cancelling an already-resolved promise is a silent no-op", async () => {
+    let h = new Harness(new SlowTarget());
+
+    let promise = h.stub.square(6);
+    let result = await promise;
+    expect(result).toBe(36);
+
+    h.clientTransport.sentLog.length = 0;
+
+    let cancelResult = (promise as any).cancel("too late");
+    expect(cancelResult).toBeUndefined();
+
+    await pumpMicrotasks();
+
+    let cancelMessages = h.clientTransport.sentLog
+      .map(m => JSON.parse(m))
+      .filter((m: any) => Array.isArray(m) && m[0] === "cancel");
+
+    expect(cancelMessages.length).toBe(0);
+
+    await pumpMicrotasks();
+  });
+
+  it("cancelling an already-disposed promise is a silent no-op", async () => {
+    let h = new Harness(new SlowTarget());
+
+    let promise = h.stub.add(2, 3);
+    await pumpMicrotasks();
+
+    (promise as any)[Symbol.dispose]();
+    await pumpMicrotasks();
+
+    h.clientTransport.sentLog.length = 0;
+
+    let cancelResult = (promise as any).cancel("after dispose");
+    expect(cancelResult).toBeUndefined();
+
+    await pumpMicrotasks();
+
+    let cancelMessages = h.clientTransport.sentLog
+      .map(m => JSON.parse(m))
+      .filter((m: any) => Array.isArray(m) && m[0] === "cancel");
+
+    expect(cancelMessages.length).toBe(0);
+
+    await pumpMicrotasks();
+  });
+
+  it("cancel does not affect unrelated concurrent calls", async () => {
+    let h = new Harness(new SlowTarget());
+
+    let promise1 = h.stub.square(10);
+    let promise2 = h.stub.square(20);
+
+    await pumpMicrotasks();
+
+    (promise1 as any).cancel("only first");
+
+    let result2 = await promise2;
+    expect(result2).toBe(400);
+
+    try {
+      await promise1;
+      throw new Error("should have thrown");
+    } catch (err: any) {
+      expect(err).toBeInstanceOf(DOMException);
+      expect(err.name).toBe("AbortError");
+    }
+
+    await pumpMicrotasks();
+  });
+
+  it("withAbortSignal returns the same promise for chaining", async () => {
+    let h = new Harness(new SlowTarget());
+    let controller = new AbortController();
+
+    let promise = h.stub.square(2);
+    let returned = (promise as any).withAbortSignal(controller.signal);
+
+    expect(returned).toBe(promise);
+
+    let result = await promise;
+    expect(result).toBe(4);
+
+    await pumpMicrotasks();
+  });
+
+  it("cancel message format is [cancel, exportId] with numeric exportId", async () => {
+    let h = new Harness(new SlowTarget());
+
+    let promise = h.stub.identity(42);
+    await pumpMicrotasks();
+
+    h.clientTransport.sentLog.length = 0;
+    (promise as any).cancel("format test");
+    await pumpMicrotasks();
+
+    let cancelMsgs = h.clientTransport.sentLog
+      .map(m => JSON.parse(m))
+      .filter((m: any) => Array.isArray(m) && m[0] === "cancel");
+
+    expect(cancelMsgs.length).toBe(1);
+    expect(cancelMsgs[0]).toHaveLength(2);
+    expect(cancelMsgs[0][0]).toBe("cancel");
+    expect(Number.isInteger(cancelMsgs[0][1])).toBe(true);
+
+    await pumpMicrotasks();
+  });
+
+  it("peer ignores cancel for a nonexistent export without error", async () => {
+    let h = new Harness(new SlowTarget());
+
+    let promise1 = h.stub.add(5, 5);
+    await pumpMicrotasks();
+
+    let exportsBefore = h.server.getStats().exports;
+
+    (promise1 as any).cancel("will be gone");
+    await pumpMicrotasks();
+
+    let exportsAfter = h.server.getStats().exports;
+    expect(exportsAfter).toBeLessThan(exportsBefore);
+
+    (promise1 as any).cancel("already gone");
+    await pumpMicrotasks();
+
+    expect(h.server.getStats().exports).toBe(exportsAfter);
+
+    let promise2 = h.stub.square(7);
+    let result2 = await promise2;
+    expect(result2).toBe(49);
+
+    await pumpMicrotasks();
+  });
+
+  it("pipeline cascade sends cancel per affected import not per stub", async () => {
+    let h = new Harness(new SlowTarget());
+
+    let parent = h.stub.makeCounter(5);
+    let child1 = parent.increment(1);
+    let child2 = parent.increment(2);
+
+    await pumpMicrotasks();
+    h.clientTransport.sentLog.length = 0;
+
+    (parent as any).cancel("cascade dedup");
+    await pumpMicrotasks();
+
+    let cancelMessages = h.clientTransport.sentLog
+      .map(m => JSON.parse(m))
+      .filter((m: any) => Array.isArray(m) && m[0] === "cancel");
+
+    expect(cancelMessages.length).toBeGreaterThan(0);
+
+    let uniqueExportIds = new Set(cancelMessages.map((m: any) => m[1]));
+    expect(uniqueExportIds.size).toBe(cancelMessages.length);
+
+    for (let p of [child1, child2]) {
+      try {
+        await p;
+        throw new Error("child should have been cancelled");
+      } catch (err: any) {
+        expect(err).toBeInstanceOf(DOMException);
+        expect(err.name).toBe("AbortError");
+      }
+    }
+
+    await pumpMicrotasks();
+  });
+
+  it("cancel of property access chain rejects the entire chain", async () => {
+    let h = new Harness(new SlowTarget());
+
+    let counterPromise = h.stub.makeCounter(100);
+    let valueAccess = counterPromise.value;
+
+    await pumpMicrotasks();
+
+    (counterPromise as any).cancel("chain cancel");
+
+    try {
+      await valueAccess;
+      throw new Error("property access should have been cancelled");
+    } catch (err: any) {
+      expect(err).toBeInstanceOf(DOMException);
+      expect(err.name).toBe("AbortError");
+      expect(err.message).toBe("chain cancel");
+    }
+
+    await pumpMicrotasks();
+  });
+
+  it("cancel with custom DOMException reason preserves the message", async () => {
+    let h = new Harness(new SlowTarget());
+
+    let promise = h.stub.square(11);
+    (promise as any).cancel(new Error("custom error object"));
+
+    try {
+      await promise;
+      throw new Error("should have thrown");
+    } catch (err: any) {
+      expect(err).toBeInstanceOf(DOMException);
+      expect(err.name).toBe("AbortError");
+      expect(err.message).toBe("Error: custom error object");
+    }
+
+    await pumpMicrotasks();
+  });
+
+  it("withAbortSignal propagates signal.reason as cancel reason", async () => {
+    let h = new Harness(new SlowTarget());
+    let controller = new AbortController();
+
+    let promise = h.stub.square(13);
+    (promise as any).withAbortSignal(controller.signal);
+
+    controller.abort("specific signal reason");
+
+    try {
+      await promise;
+      throw new Error("should have thrown");
+    } catch (err: any) {
+      expect(err).toBeInstanceOf(DOMException);
+      expect(err.name).toBe("AbortError");
+      expect(err.message).toBe("specific signal reason");
+    }
+
+    await pumpMicrotasks();
+  });
+
+  it("cancel before pull still rejects correctly", async () => {
+    let h = new Harness(new SlowTarget());
+
+    let promise = h.stub.add(7, 8);
+    (promise as any).cancel("before pull");
+
+    try {
+      await promise;
+      throw new Error("should have thrown");
+    } catch (err: any) {
+      expect(err).toBeInstanceOf(DOMException);
+      expect(err.name).toBe("AbortError");
+    }
+
+    await pumpMicrotasks();
+  });
+
+  it("cancel is idempotent - multiple calls produce one cancel message", async () => {
+    let h = new Harness(new SlowTarget());
+
+    let promise = h.stub.square(3);
+    await pumpMicrotasks();
+
+    h.clientTransport.sentLog.length = 0;
+
+    (promise as any).cancel("first");
+    (promise as any).cancel("second");
+    (promise as any).cancel("third");
+
+    await pumpMicrotasks();
+
+    let cancelMessages = h.clientTransport.sentLog
+      .map(m => JSON.parse(m))
+      .filter((m: any) => Array.isArray(m) && m[0] === "cancel");
+
+    expect(cancelMessages.length).toBe(1);
+
+    await pumpMicrotasks();
+  });
+
+  it("interleaved cancel and await on independent promises", async () => {
+    let h = new Harness(new SlowTarget());
+
+    let p1 = h.stub.square(2);
+    let p2 = h.stub.square(3);
+    let p3 = h.stub.square(4);
+
+    await pumpMicrotasks();
+
+    (p1 as any).cancel("cancel p1");
+    (p3 as any).cancel("cancel p3");
+
+    let result2 = await p2;
+    expect(result2).toBe(9);
+
+    try {
+      await p1;
+      throw new Error("p1 should be cancelled");
+    } catch (err: any) {
+      expect(err.name).toBe("AbortError");
+    }
+
+    try {
+      await p3;
+      throw new Error("p3 should be cancelled");
+    } catch (err: any) {
+      expect(err.name).toBe("AbortError");
+    }
+
+    await pumpMicrotasks();
+  });
+
+  it("cascade sends exactly one cancel message for root only", async () => {
+    let h = new Harness(new SlowTarget());
+
+    let parent = h.stub.makeCounter(0);
+    let child = parent.increment(1);
+
+    await pumpMicrotasks();
+    h.clientTransport.sentLog.length = 0;
+
+    (parent as any).cancel("root only");
+    await pumpMicrotasks();
+
+    let cancelMessages = h.clientTransport.sentLog
+      .map(m => JSON.parse(m))
+      .filter((m: any) => Array.isArray(m) && m[0] === "cancel");
+
+    expect(cancelMessages.length).toBe(1);
+
+    try {
+      await child;
+      throw new Error("child should be cancelled");
+    } catch (err: any) {
+      expect(err).toBeInstanceOf(DOMException);
+      expect(err.name).toBe("AbortError");
+    }
+
+    await pumpMicrotasks();
+  });
+});
