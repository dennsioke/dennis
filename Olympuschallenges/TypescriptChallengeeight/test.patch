index 00000000..4fad41d7
--- /dev/null
+++ b/tests/unit/swagger/discriminatedUnion.spec.ts
@@ -0,0 +1,579 @@
+import { ExtendedSpecConfig } from '@tsoa/cli/cli';
+import { MetadataGenerator } from '@tsoa/cli/metadataGeneration/metadataGenerator';
+import { SpecGenerator2 } from '@tsoa/cli/swagger/specGenerator2';
+import { SpecGenerator3 } from '@tsoa/cli/swagger/specGenerator3';
+import { SpecGenerator31 } from '@tsoa/cli/swagger/specGenerator31';
+import { DefaultRouteGenerator } from '@tsoa/cli/routeGeneration/defaultRouteGenerator';
+import { Swagger, Tsoa, TsoaRoute, FieldErrors, ValidationService } from '@tsoa/runtime';
+import { expect } from 'chai';
+import 'mocha';
+import { getDefaultExtendedOptions } from '../../fixtures/defaultOptions';
+
+describe('Discriminated union support', () => {
+  const metadata = new MetadataGenerator('./fixtures/controllers/discriminatedUnionController.ts').Generate();
+  const defaultOptions: ExtendedSpecConfig = getDefaultExtendedOptions();
+  const spec3 = new SpecGenerator3(metadata, defaultOptions).GetSpec();
+  const spec31 = new SpecGenerator31(metadata, defaultOptions).GetSpec();
+  const spec2 = new SpecGenerator2(metadata, defaultOptions).GetSpec();
+
+  const getComponentSchema = (name: string, spec: Swagger.Spec3): Swagger.Schema3 => {
+    const spec30 = spec as Swagger.Spec30;
+    if (!spec30.components.schemas) {
+      throw new Error(`No schemas found`);
+    }
+    const schema = spec30.components.schemas[name];
+    if (!schema) {
+      throw new Error(`Schema ${name} not found. Available: ${Object.keys(spec30.components.schemas).join(', ')}`);
+    }
+    return schema;
+  };
+
+  describe('OpenAPI 3.0', () => {
+    it('should emit oneOf instead of anyOf for discriminated union Shape', () => {
+      const shape = getComponentSchema('Shape', spec3);
+      expect((shape as any).oneOf).to.be.an('array').with.lengthOf(3);
+      expect((shape as any).anyOf).to.be.undefined;
+    });
+
+    it('should include discriminator with propertyName kind for Shape', () => {
+      const shape = getComponentSchema('Shape', spec3);
+      expect((shape as any).discriminator).to.exist;
+      expect((shape as any).discriminator.propertyName).to.equal('kind');
+    });
+
+    it('should include correct discriminator mapping for Shape', () => {
+      const shape = getComponentSchema('Shape', spec3);
+      const mapping = (shape as any).discriminator.mapping;
+      expect(mapping).to.deep.equal({
+        circle: '#/components/schemas/Circle',
+        square: '#/components/schemas/Square',
+        triangle: '#/components/schemas/Triangle',
+      });
+    });
+
+    it('should detect discriminator on status property for ApiResult', () => {
+      const apiResult = getComponentSchema('ApiResult', spec3);
+      expect((apiResult as any).oneOf).to.be.an('array').with.lengthOf(3);
+      expect((apiResult as any).anyOf).to.be.undefined;
+      expect((apiResult as any).discriminator).to.exist;
+      expect((apiResult as any).discriminator.propertyName).to.equal('status');
+      expect((apiResult as any).discriminator.mapping).to.deep.equal({
+        success: '#/components/schemas/SuccessResult',
+        error: '#/components/schemas/ErrorResult',
+        pending: '#/components/schemas/PendingResult',
+      });
+    });
+
+    it('should emit anyOf without discriminator for non-discriminated union Pet', () => {
+      const pet = getComponentSchema('Pet', spec3);
+      expect((pet as any).anyOf).to.be.an('array');
+      expect((pet as any).oneOf).to.be.undefined;
+      expect((pet as any).discriminator).to.be.undefined;
+    });
+
+    it('should preserve discriminator and nullable for nullable discriminated union', () => {
+      const nullableShape = getComponentSchema('NullableShape', spec3);
+      expect((nullableShape as any).oneOf).to.be.an('array').with.lengthOf(3);
+      expect((nullableShape as any).discriminator).to.exist;
+      expect((nullableShape as any).discriminator.propertyName).to.equal('kind');
+      expect((nullableShape as any).nullable).to.equal(true);
+      expect((nullableShape as any).discriminator.mapping).to.deep.equal({
+        circle: '#/components/schemas/Circle',
+        square: '#/components/schemas/Square',
+        triangle: '#/components/schemas/Triangle',
+      });
+    });
+
+    it('should detect discriminator for CrudAction with five variants', () => {
+      const crudAction = getComponentSchema('CrudAction', spec3);
+      expect((crudAction as any).oneOf).to.be.an('array').with.lengthOf(5);
+      expect((crudAction as any).discriminator).to.exist;
+      expect((crudAction as any).discriminator.propertyName).to.equal('action');
+      expect(Object.keys((crudAction as any).discriminator.mapping)).to.have.lengthOf(5);
+      expect((crudAction as any).discriminator.mapping).to.have.property('create');
+      expect((crudAction as any).discriminator.mapping).to.have.property('read');
+      expect((crudAction as any).discriminator.mapping).to.have.property('update');
+      expect((crudAction as any).discriminator.mapping).to.have.property('delete');
+      expect((crudAction as any).discriminator.mapping).to.have.property('list');
+    });
+
+    it('should generate correct discriminant enum property in member schemas', () => {
+      const circle = getComponentSchema('Circle', spec3);
+      expect(circle.properties).to.exist;
+      expect(circle.properties!.kind).to.exist;
+      expect(circle.properties!.kind.type).to.equal('string');
+      expect(circle.properties!.kind.enum).to.deep.equal(['circle']);
+      expect(circle.required).to.include('kind');
+
+      const square = getComponentSchema('Square', spec3);
+      expect(square.properties!.kind.enum).to.deep.equal(['square']);
+
+      const triangle = getComponentSchema('Triangle', spec3);
+      expect(triangle.properties!.kind.enum).to.deep.equal(['triangle']);
+    });
+
+    it('should reference discriminated union correctly as a nested property of Drawing', () => {
+      const drawing = getComponentSchema('Drawing', spec3);
+      expect(drawing.properties).to.exist;
+      expect(drawing.properties!.shape).to.exist;
+      expect(drawing.properties!.shape.$ref).to.equal('#/components/schemas/Shape');
+    });
+
+    it('should reference discriminated union in request body schema', () => {
+      const pathItem = spec3.paths['/DiscriminatedUnion/Shape'];
+      expect(pathItem).to.exist;
+      expect(pathItem.post).to.exist;
+      const requestBody = (pathItem.post as Swagger.Operation3).requestBody as Swagger.RequestBody;
+      expect(requestBody).to.exist;
+      expect(requestBody.content['application/json']).to.exist;
+      const schema = requestBody.content['application/json'].schema as any;
+      expect(schema.$ref).to.equal('#/components/schemas/Shape');
+    });
+
+    it('should reference discriminated union in response schema', () => {
+      const pathItem = spec3.paths['/DiscriminatedUnion/Shape'];
+      expect(pathItem).to.exist;
+      expect(pathItem.get).to.exist;
+      const response = (pathItem.get as Swagger.Operation3).responses['200'] as Swagger.Response3;
+      expect(response.content).to.exist;
+      const schema = response.content!['application/json'].schema as any;
+      expect(schema.$ref).to.equal('#/components/schemas/Shape');
+    });
+  });
+
+  describe('OpenAPI 3.1', () => {
+    it('should emit oneOf with discriminator for Shape in 3.1 spec', () => {
+      const shape = getComponentSchema('Shape', spec31);
+      expect((shape as any).oneOf).to.be.an('array').with.lengthOf(3);
+      expect((shape as any).anyOf).to.be.undefined;
+      expect((shape as any).discriminator).to.exist;
+      expect((shape as any).discriminator.propertyName).to.equal('kind');
+      expect((shape as any).discriminator.mapping).to.deep.equal({
+        circle: '#/components/schemas/Circle',
+        square: '#/components/schemas/Square',
+        triangle: '#/components/schemas/Triangle',
+      });
+    });
+
+    it('should emit oneOf with discriminator for ApiResult in 3.1 spec', () => {
+      const apiResult = getComponentSchema('ApiResult', spec31);
+      expect((apiResult as any).oneOf).to.be.an('array').with.lengthOf(3);
+      expect((apiResult as any).discriminator).to.exist;
+      expect((apiResult as any).discriminator.propertyName).to.equal('status');
+    });
+
+    it('should emit anyOf without discriminator for non-discriminated union Pet in 3.1 spec', () => {
+      const pet = getComponentSchema('Pet', spec31);
+      expect((pet as any).anyOf).to.be.an('array');
+      expect((pet as any).oneOf).to.be.undefined;
+      expect((pet as any).discriminator).to.be.undefined;
+    });
+
+    it('should handle nullable discriminated union with null type member instead of nullable flag in 3.1', () => {
+      const nullableShape = getComponentSchema('NullableShape', spec31);
+      expect((nullableShape as any).oneOf).to.be.an('array');
+      expect((nullableShape as any).discriminator).to.exist;
+      expect((nullableShape as any).discriminator.propertyName).to.equal('kind');
+      const oneOfMembers = (nullableShape as any).oneOf as any[];
+      const nullMember = oneOfMembers.find((m: any) => m.type === 'null');
+      expect(nullMember).to.exist;
+      expect((nullableShape as any).nullable).to.be.undefined;
+      const refMembers = oneOfMembers.filter((m: any) => m.$ref);
+      expect(refMembers).to.have.lengthOf(3);
+    });
+  });
+
+  describe('Swagger 2.0', () => {
+    const getDefinition = (name: string): Swagger.Schema2 => {
+      const defs = spec2.definitions;
+      if (!defs) {
+        throw new Error('No definitions found');
+      }
+      const def = defs[name];
+      if (!def) {
+        throw new Error(`Definition ${name} not found. Available: ${Object.keys(defs).join(', ')}`);
+      }
+      return def as Swagger.Schema2;
+    };
+
+    it('should emit discriminator property name on base schema for Shape', () => {
+      const shape = getDefinition('Shape');
+      expect((shape as any).discriminator).to.equal('kind');
+    });
+
+    it('should include kind as required property on Shape base schema', () => {
+      const shape = getDefinition('Shape');
+      expect(shape.required).to.include('kind');
+    });
+
+    it('should include kind string property on Shape base schema', () => {
+      const shape = getDefinition('Shape');
+      expect(shape.properties).to.exist;
+      expect(shape.properties!.kind).to.exist;
+      expect(shape.properties!.kind.type).to.equal('string');
+    });
+
+    it('should emit allOf inheritance for Circle member schema', () => {
+      const circle = getDefinition('Circle');
+      expect(circle.allOf).to.be.an('array').with.lengthOf(2);
+      expect(circle.allOf![0]).to.deep.equal({ $ref: '#/definitions/Shape' });
+      const ownProps = circle.allOf![1] as Swagger.Schema2;
+      expect(ownProps.type).to.equal('object');
+      expect(ownProps.properties).to.exist;
+      expect(ownProps.properties!.radius).to.exist;
+    });
+
+    it('should not include discriminant property in own properties of member schema', () => {
+      const circle = getDefinition('Circle');
+      const ownProps = circle.allOf![1] as Swagger.Schema2;
+      expect(ownProps.properties!.kind).to.be.undefined;
+    });
+
+    it('should emit allOf inheritance for Square member schema', () => {
+      const square = getDefinition('Square');
+      expect(square.allOf).to.be.an('array').with.lengthOf(2);
+      expect(square.allOf![0]).to.deep.equal({ $ref: '#/definitions/Shape' });
+      const ownProps = square.allOf![1] as Swagger.Schema2;
+      expect(ownProps.properties).to.exist;
+      expect(ownProps.properties!.sideLength).to.exist;
+    });
+
+    it('should emit allOf inheritance for Triangle member schema', () => {
+      const triangle = getDefinition('Triangle');
+      expect(triangle.allOf).to.be.an('array').with.lengthOf(2);
+      expect(triangle.allOf![0]).to.deep.equal({ $ref: '#/definitions/Shape' });
+      const ownProps = triangle.allOf![1] as Swagger.Schema2;
+      expect(ownProps.properties).to.exist;
+      expect(ownProps.properties!.base).to.exist;
+      expect(ownProps.properties!.height).to.exist;
+    });
+
+    it('should emit discriminator on ApiResult base schema', () => {
+      const apiResult = getDefinition('ApiResult');
+      expect((apiResult as any).discriminator).to.equal('status');
+      expect(apiResult.required).to.include('status');
+    });
+
+    it('should emit allOf inheritance for SuccessResult member schema', () => {
+      const success = getDefinition('SuccessResult');
+      expect(success.allOf).to.be.an('array').with.lengthOf(2);
+      expect(success.allOf![0]).to.deep.equal({ $ref: '#/definitions/ApiResult' });
+      const ownProps = success.allOf![1] as Swagger.Schema2;
+      expect(ownProps.properties).to.exist;
+      expect(ownProps.properties!.data).to.exist;
+      expect(ownProps.properties!.status).to.be.undefined;
+    });
+
+    it('should not use allOf inheritance for non-discriminated union members', () => {
+      const dog = getDefinition('Dog');
+      expect(dog.allOf).to.be.undefined;
+      expect(dog.type).to.equal('object');
+      expect(dog.properties).to.exist;
+      expect(dog.properties!.name).to.exist;
+    });
+
+    it('should emit non-discriminated union as plain object type in Swagger 2', () => {
+      const pet = getDefinition('Pet');
+      expect(pet.type).to.equal('object');
+      expect((pet as any).discriminator).to.be.undefined;
+      expect(pet.allOf).to.be.undefined;
+    });
+
+    it('should emit discriminator on CrudAction base schema with action property', () => {
+      const crudAction = getDefinition('CrudAction');
+      expect((crudAction as any).discriminator).to.equal('action');
+      expect(crudAction.required).to.include('action');
+      expect(crudAction.properties).to.exist;
+      expect(crudAction.properties!.action).to.exist;
+      expect(crudAction.properties!.action.type).to.equal('string');
+    });
+
+    it('should emit allOf for all five CrudAction member schemas', () => {
+      const members = ['CreateAction', 'ReadAction', 'UpdateAction', 'DeleteAction', 'ListAction'];
+      for (const memberName of members) {
+        const member = getDefinition(memberName);
+        expect(member.allOf, `${memberName} should have allOf`).to.be.an('array').with.lengthOf(2);
+        expect(member.allOf![0], `${memberName} should reference CrudAction base`).to.deep.equal({ $ref: '#/definitions/CrudAction' });
+        const ownProps = member.allOf![1] as Swagger.Schema2;
+        expect(ownProps.properties!.action, `${memberName} should not duplicate action in own props`).to.be.undefined;
+      }
+    });
+
+    it('should reference discriminated union correctly in Drawing definition', () => {
+      const drawing = getDefinition('Drawing');
+      expect(drawing.properties).to.exist;
+      expect(drawing.properties!.shape).to.exist;
+      expect(drawing.properties!.shape.$ref).to.equal('#/definitions/Shape');
+    });
+
+    it('should preserve own required properties in member allOf schemas', () => {
+      const circle = getDefinition('Circle');
+      const ownProps = circle.allOf![1] as Swagger.Schema2;
+      expect(ownProps.required).to.include('radius');
+    });
+  });
+
+  describe('Metadata detection of discriminated unions', () => {
+    it('should detect discriminator on Shape type alias union in referenceTypeMap', () => {
+      const shapeRef = metadata.referenceTypeMap['Shape'];
+      expect(shapeRef).to.exist;
+      expect(shapeRef.dataType).to.equal('refAlias');
+      if (shapeRef.dataType === 'refAlias') {
+        expect(shapeRef.type.dataType).to.equal('union');
+        const unionType = shapeRef.type as Tsoa.UnionType;
+        expect((unionType as any).discriminator).to.exist;
+        expect((unionType as any).discriminator.propertyName).to.equal('kind');
+        const mapping = (unionType as any).discriminator.mapping;
+        expect(mapping).to.deep.equal({
+          circle: 'Circle',
+          square: 'Square',
+          triangle: 'Triangle',
+        });
+      }
+    });
+
+    it('should detect discriminator on ApiResult with status property', () => {
+      const apiResultRef = metadata.referenceTypeMap['ApiResult'];
+      expect(apiResultRef).to.exist;
+      expect(apiResultRef.dataType).to.equal('refAlias');
+      if (apiResultRef.dataType === 'refAlias') {
+        const unionType = apiResultRef.type as Tsoa.UnionType;
+        expect((unionType as any).discriminator).to.exist;
+        expect((unionType as any).discriminator.propertyName).to.equal('status');
+        expect((unionType as any).discriminator.mapping).to.have.property('success', 'SuccessResult');
+        expect((unionType as any).discriminator.mapping).to.have.property('error', 'ErrorResult');
+        expect((unionType as any).discriminator.mapping).to.have.property('pending', 'PendingResult');
+      }
+    });
+
+    it('should NOT detect discriminator on Pet union (no common literal property)', () => {
+      const petRef = metadata.referenceTypeMap['Pet'];
+      expect(petRef).to.exist;
+      expect(petRef.dataType).to.equal('refAlias');
+      if (petRef.dataType === 'refAlias') {
+        const unionType = petRef.type as Tsoa.UnionType;
+        expect((unionType as any).discriminator).to.be.undefined;
+      }
+    });
+
+    it('should detect discriminator on CrudAction with five variants', () => {
+      const crudRef = metadata.referenceTypeMap['CrudAction'];
+      expect(crudRef).to.exist;
+      expect(crudRef.dataType).to.equal('refAlias');
+      if (crudRef.dataType === 'refAlias') {
+        const unionType = crudRef.type as Tsoa.UnionType;
+        expect((unionType as any).discriminator).to.exist;
+        expect((unionType as any).discriminator.propertyName).to.equal('action');
+        expect(Object.keys((unionType as any).discriminator.mapping)).to.have.lengthOf(5);
+      }
+    });
+
+    it('should detect discriminator on NullableShape even with null member', () => {
+      const nullableRef = metadata.referenceTypeMap['NullableShape'];
+      expect(nullableRef).to.exist;
+      expect(nullableRef.dataType).to.equal('refAlias');
+      if (nullableRef.dataType === 'refAlias') {
+        const unionType = nullableRef.type as Tsoa.UnionType;
+        expect((unionType as any).discriminator).to.exist;
+        expect((unionType as any).discriminator.propertyName).to.equal('kind');
+      }
+    });
+  });
+
+  describe('Route model generation with discriminator', () => {
+    const routeGenerator = new DefaultRouteGenerator(metadata, {
+      bodyCoercion: true,
+      entryFile: 'mockEntryFile',
+      routesDir: 'mockRoutesDir',
+      noImplicitAdditionalProperties: 'silently-remove-extras',
+    });
+    const models = routeGenerator.buildModels();
+
+    it('should propagate discriminator in route model for Shape type alias', () => {
+      const shapeModel = models['Shape'];
+      expect(shapeModel).to.exist;
+      expect(shapeModel.dataType).to.equal('refAlias');
+      if (shapeModel.dataType === 'refAlias') {
+        expect(shapeModel.type.dataType).to.equal('union');
+        expect(shapeModel.type.subSchemas).to.be.an('array').with.lengthOf(3);
+        expect((shapeModel.type as any).discriminator).to.exist;
+        expect((shapeModel.type as any).discriminator.propertyName).to.equal('kind');
+        const mapping = (shapeModel.type as any).discriminator.mapping;
+        expect(mapping).to.have.property('circle');
+        expect(mapping).to.have.property('square');
