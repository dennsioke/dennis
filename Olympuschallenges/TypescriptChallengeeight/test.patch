+++ b/tests/fixtures/controllers/discriminatedUnionController.ts
@@ -0,0 +1,45 @@
+import { Body, Controller, Get, Post, Route } from '@tsoa/runtime';
+import {
+  Shape,
+  ApiResult,
+  NullableShape,
+  Pet,
+  CrudAction,
+  Drawing,
+} from '../discriminatedUnionModel';
+
+@Route('DiscriminatedUnion')
+export class DiscriminatedUnionController extends Controller {
+  @Get('Shape')
+  public async getShape(): Promise<Shape> {
+    return { kind: 'circle', radius: 5 };
+  }
+
+  @Post('Shape')
+  public async postShape(@Body() body: Shape): Promise<Shape> {
+    return body;
+  }
+
+  @Get('ApiResult')
+  public async getApiResult(): Promise<ApiResult> {
+    return { status: 'success', data: 'ok' };
+  }
+
+  @Post('NullableShape')
+  public async postNullableShape(@Body() body: NullableShape): Promise<void> {}
+
+  @Get('Pet')
+  public async getPet(): Promise<Pet> {
+    return { name: 'Buddy', breed: 'Golden Retriever' };
+  }
+
+  @Post('CrudAction')
+  public async postCrudAction(@Body() body: CrudAction): Promise<CrudAction> {
+    return body;
+  }
+
+  @Get('Drawing')
+  public async getDrawing(): Promise<Drawing> {
+    return { id: 1, shape: { kind: 'circle', radius: 5 }, color: 'red' };
+  }
+}
diff --git a/tests/fixtures/discriminatedUnionModel.ts b/tests/fixtures/discriminatedUnionModel.ts
new file mode 100644
index 00000000..3f3efa71
--- /dev/null
+++ b/tests/fixtures/discriminatedUnionModel.ts
@@ -0,0 +1,83 @@
+export interface Circle {
+  kind: 'circle';
+  radius: number;
+}
+
+export interface Square {
+  kind: 'square';
+  sideLength: number;
+}
+
+export interface Triangle {
+  kind: 'triangle';
+  base: number;
+  height: number;
+}
+
+export type Shape = Circle | Square | Triangle;
+
+export interface SuccessResult {
+  status: 'success';
+  data: string;
+}
+
+export interface ErrorResult {
+  status: 'error';
+  message: string;
+  code: number;
+}
+
+export interface PendingResult {
+  status: 'pending';
+  progress: number;
+}
+
+export type ApiResult = SuccessResult | ErrorResult | PendingResult;
+
+export type NullableShape = Circle | Square | Triangle | null;
+
+export interface Dog {
+  name: string;
+  breed: string;
+}
+
+export interface Cat {
+  name: string;
+  indoor: boolean;
+}
+
+export type Pet = Dog | Cat;
+
+export interface CreateAction {
+  action: 'create';
+  resource: string;
+}
+
+export interface ReadAction {
+  action: 'read';
+  resourceId: string;
+}
+
+export interface UpdateAction {
+  action: 'update';
+  resourceId: string;
+  data: string;
+}
+
+export interface DeleteAction {
+  action: 'delete';
+  resourceId: string;
+}
+
+export interface ListAction {
+  action: 'list';
+  filter: string;
+}
+
+export type CrudAction = CreateAction | ReadAction | UpdateAction | DeleteAction | ListAction;
+
+export interface Drawing {
+  id: number;
+  shape: Shape;
+  color: string;
+}
diff --git a/tests/unit/swagger/discriminatedUnion.spec.ts b/tests/unit/swagger/discriminatedUnion.spec.ts
