@@ -0,0 +1,89 @@
+export interface Circle {
+  kind: 'circle';
+  radius: number;
+}
+
+export interface Square {
+  kind: 'square';
+  sideLength: number;
+}
+
+export interface Triangle {
+  kind: 'triangle';
+  base: number;
+  height: number;
+}
+
+export type Shape = Circle | Square | Triangle;
+
+export interface SuccessResult {
+  status: 'success';
+  data: string;
+}
+
+export interface ErrorResult {
+  status: 'error';
+  message: string;
+  code: number;
+}
+
+export interface PendingResult {
+  status: 'pending';
+  progress: number;
+}
+
+export type ApiResult = SuccessResult | ErrorResult | PendingResult;
+
+export type NullableShape = Circle | Square | Triangle | null;
+
+export interface Dog {
+  name: string;
+  breed: string;
+}
+
+export interface Cat {
+  name: string;
+  indoor: boolean;
+}
+
+export type Pet = Dog | Cat;
+
+export interface CreateAction {
+  action: 'create';
+  resource: string;
+}
+
+export interface ReadAction {
+  action: 'read';
+  resourceId: string;
+}
+
+export interface UpdateAction {
+  action: 'update';
+  resourceId: string;
+  data: string;
+}
+
+export interface DeleteAction {
+  action: 'delete';
+  resourceId: string;
+}
+
+export interface ListAction {
+  action: 'list';
+  filter: string;
+}
+
+export type CrudAction = CreateAction | ReadAction | UpdateAction | DeleteAction | ListAction;
+
+export interface Drawing {
+  id: number;
+  shape: Shape;
+  color: string;
+}
+
+export interface Marker {
+  label: string;
+}
+
+export type PrimitiveOrObject = string | Marker;
diff --git a/tests/unit/swagger/discriminatedUnion.spec.ts b/tests/unit/swagger/discriminatedUnion.spec.ts
