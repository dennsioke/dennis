diff --git a/test.sh b/test.sh
new file mode 100755
index 0000000..930fb05
--- /dev/null
+++ b/test.sh
@@ -0,0 +1,38 @@
+#!/usr/bin/env bash
+set -euo pipefail
+
+OUTPUT_PATH=""
+MODE=""
+
+while [[ $# -gt 0 ]]; do
+  case "$1" in
+    --output_path)
+      OUTPUT_PATH="$2"
+      shift 2
+      ;;
+    base|new)
+      MODE="$1"
+      shift
+      ;;
+    *)
+      echo "Usage: $0 --output_path <path> [base|new]" >&2
+      exit 1
+      ;;
+  esac
+done
+
+if [ -z "$MODE" ]; then
+  echo "Usage: $0 --output_path <path> [base|new]" >&2
+  exit 1
+fi
+
+REPORTER_ARGS=()
+if [ -n "$OUTPUT_PATH" ]; then
+  REPORTER_ARGS=(--reporter=junit --outputFile="$OUTPUT_PATH")
+fi
+
+if [ "$MODE" = "base" ]; then
+  npx vitest run --exclude 'tests/prefix-items-tuples.test.ts' "${REPORTER_ARGS[@]}"
+elif [ "$MODE" = "new" ]; then
+  npx vitest run tests/prefix-items-tuples.test.ts "${REPORTER_ARGS[@]}"
+fi
diff --git a/tests/prefix-items-tuples.test.ts b/tests/prefix-items-tuples.test.ts
new file mode 100644
index 0000000..d5bbd69
--- /dev/null
+++ b/tests/prefix-items-tuples.test.ts
@@ -0,0 +1,229 @@
+import * as fs from "node:fs/promises";
+import * as os from "node:os";
+import * as path from "node:path";
+import { afterAll, beforeAll, describe, expect, test } from "vitest";
+import { generateApi } from "../src/index.js";
+
+describe("prefixItems tuple type generation", async () => {
+  let tmpdir: string;
+
+  beforeAll(async () => {
+    tmpdir = await fs.mkdtemp(
+      path.join(os.tmpdir(), "swagger-typescript-api-tuples-"),
+    );
+  });
+
+  afterAll(async () => {
+    await fs.rm(tmpdir, { recursive: true });
+  });
+
+  async function generate(schemas: Record<string, unknown>) {
+    const result = await generateApi({
+      spec: {
+        openapi: "3.1.0",
+        info: { title: "TupleTest", version: "1.0.0" },
+        paths: {},
+        components: { schemas },
+      } as any,
+      output: tmpdir,
+      fileName: "tuples",
+      silent: true,
+      generateClient: false,
+      sortTypes: true,
+    });
+    return result.files[0]?.fileContent ?? "";
+  }
+
+  test("basic prefixItems generates a tuple type", async () => {
+    const content = await generate({
+      Coordinate: {
+        type: "array",
+        prefixItems: [
+          { type: "string" },
+          { type: "number" },
+          { type: "boolean" },
+        ],
+      },
+    });
+    expect(content).toContain("[string, number, boolean]");
+    expect(content).not.toMatch(/\(string \| number \| boolean\)\[\]/);
+  });
+
+  test("single-element prefixItems generates a single-element tuple", async () => {
+    const content = await generate({
+      Wrapper: {
+        type: "array",
+        prefixItems: [{ type: "integer" }],
+      },
+    });
+    expect(content).toContain("[number]");
+  });
+
+  test("prefixItems with items schema produces rest element", async () => {
+    const content = await generate({
+      HeadAndTail: {
+        type: "array",
+        prefixItems: [{ type: "number" }],
+        items: { type: "string" },
+      },
+    });
+    expect(content).toContain("[number, ...string[]]");
+  });
+
+  test("prefixItems with items false produces strict tuple", async () => {
+    const content = await generate({
+      StrictPair: {
+        type: "array",
+        prefixItems: [{ type: "string" }, { type: "number" }],
+        items: false,
+      },
+    });
+    expect(content).toContain("[string, number]");
+    expect(content).not.toContain("...");
+  });
+
+  test("prefixItems without items key produces tuple with no rest element", async () => {
+    const content = await generate({
+      NoItemsKey: {
+        type: "array",
+        prefixItems: [{ type: "string" }, { type: "boolean" }],
+      },
+    });
+    const match = content.match(/type\s+NoItemsKey\s*=\s*([^;]+)/);
+    expect(match).not.toBeNull();
+    expect(match![1]).toContain("[string, boolean]");
+    expect(match![1]).not.toContain("...");
+  });
+
+  test("minItems less than prefixItems length marks trailing entries optional", async () => {
+    const content = await generate({
+      PartialTuple: {
+        type: "array",
+        prefixItems: [
+          { type: "string" },
+          { type: "number" },
+          { type: "boolean" },
+        ],
+        items: false,
+        minItems: 1,
+      },
+    });
+    expect(content).toContain("string,");
+    expect(content).toMatch(/number\?/);
+    expect(content).toMatch(/boolean\?/);
+  });
+
+  test("minItems equal to prefixItems length keeps all entries required", async () => {
+    const content = await generate({
+      FullTuple: {
+        type: "array",
+        prefixItems: [{ type: "string" }, { type: "number" }],
+        items: false,
+        minItems: 2,
+      },
+    });
+    expect(content).toContain("[string, number]");
+    expect(content).not.toMatch(/string\?/);
+    expect(content).not.toMatch(/number\?/);
+  });
+
+  test("prefixItems entries with $ref resolve to component type name", async () => {
+    const content = await generate({
+      Pet: {
+        type: "object",
+        properties: {
+          name: { type: "string" },
+        },
+      },
+      PetPair: {
+        type: "array",
+        prefixItems: [
+          { $ref: "#/components/schemas/Pet" },
+          { type: "number" },
+        ],
+        items: false,
+      },
+    });
+    expect(content).toMatch(/\[Pet,\s*number\]/);
+  });
+
+  test("nullable array with prefixItems produces tuple unioned with null", async () => {
+    const content = await generate({
+      NullableTuple: {
+        type: "array",
+        prefixItems: [{ type: "string" }, { type: "number" }],
+        items: false,
+        nullable: true,
+      },
+    });
+    expect(content).toMatch(/\[string,\s*number\]\s*\|\s*null/);
+  });
+
+  test("nested prefixItems produces nested tuple", async () => {
+    const content = await generate({
+      Nested: {
+        type: "array",
+        prefixItems: [
+          { type: "string" },
+          {
+            type: "array",
+            prefixItems: [{ type: "number" }, { type: "boolean" }],
+            items: false,
+          },
+        ],
+        items: false,
+      },
+    });
+    expect(content).toMatch(/\[string,\s*\[number,\s*boolean\]\]/);
+  });
+
+  test("prefixItems as object property field generates tuple type", async () => {
+    const content = await generate({
+      GeoPoint: {
+        type: "object",
+        properties: {
+          coordinates: {
+            type: "array",
+            prefixItems: [{ type: "number" }, { type: "number" }],
+            items: false,
+          },
+          label: { type: "string" },
+        },
+      },
+    });
+    expect(content).toMatch(/coordinates.*\[number,\s*number\]/s);
+    expect(content).toMatch(/label.*string/s);
+  });
+
+  test("prefixItems with minItems 0 makes all entries optional", async () => {
+    const content = await generate({
+      AllOptional: {
+        type: "array",
+        prefixItems: [{ type: "string" }, { type: "number" }],
+        items: false,
+        minItems: 0,
+      },
+    });
+    expect(content).toMatch(/string\?/);
+    expect(content).toMatch(/number\?/);
+  });
+
+  test("prefixItems with rest element and optional entries combine correctly", async () => {
+    const content = await generate({
+      Complex: {
+        type: "array",
+        prefixItems: [
+          { type: "string" },
+          { type: "number" },
+          { type: "boolean" },
+        ],
+        items: { type: "integer" },
+        minItems: 1,
+      },
+    });
+    expect(content).toContain("string,");
+    expect(content).toMatch(/number\?/);
+    expect(content).toMatch(/boolean\?/);
+    expect(content).toMatch(/\.\.\.number\[\]/);
+  });
+});
