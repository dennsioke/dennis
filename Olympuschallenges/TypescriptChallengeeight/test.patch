@@ -0,0 +1,51 @@
+import { Body, Controller, Get, Post, Route } from '@tsoa/runtime';
+import {
+  Shape,
+  ApiResult,
+  NullableShape,
+  Pet,
+  CrudAction,
+  Drawing,
+  PrimitiveOrObject,
+} from '../discriminatedUnionModel';
+
+@Route('DiscriminatedUnion')
+export class DiscriminatedUnionController extends Controller {
+  @Get('Shape')
+  public async getShape(): Promise<Shape> {
+    return { kind: 'circle', radius: 5 };
+  }
+
+  @Post('Shape')
+  public async postShape(@Body() body: Shape): Promise<Shape> {
+    return body;
+  }
+
+  @Get('ApiResult')
+  public async getApiResult(): Promise<ApiResult> {
+    return { status: 'success', data: 'ok' };
+  }
+
+  @Post('NullableShape')
+  public async postNullableShape(@Body() body: NullableShape): Promise<void> {}
+
+  @Get('Pet')
+  public async getPet(): Promise<Pet> {
+    return { name: 'Buddy', breed: 'Golden Retriever' };
+  }
+
+  @Post('CrudAction')
+  public async postCrudAction(@Body() body: CrudAction): Promise<CrudAction> {
+    return body;
+  }
+
+  @Get('Drawing')
+  public async getDrawing(): Promise<Drawing> {
+    return { id: 1, shape: { kind: 'circle', radius: 5 }, color: 'red' };
+  }
+
+  @Post('PrimitiveOrObject')
+  public async postPrimitiveOrObject(@Body() body: PrimitiveOrObject): Promise<PrimitiveOrObject> {
+    return body;
+  }
+}
diff --git a/tests/fixtures/discriminatedUnionModel.ts b/tests/fixtures/discriminatedUnionModel.ts
new file mode 100644
index 00000000..52436395
