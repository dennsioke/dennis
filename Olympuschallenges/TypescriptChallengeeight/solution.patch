+import type { TreeAdapter, TreeAdapterTypeMap } from '../tree-adapters/interface.js';
+import type { Attribute } from '../common/token.js';
+import { NS } from '../common/html.js';
+
+export function isEqualNode<T extends TreeAdapterTypeMap>(
+    nodeA: T['node'],
+    nodeB: T['node'],
+    adapter: TreeAdapter<T>,
+): boolean {
+    const aIsElement = adapter.isElementNode(nodeA);
+    const bIsElement = adapter.isElementNode(nodeB);
+
+    if (aIsElement !== bIsElement) return false;
+
+    if (aIsElement && bIsElement) {
+        return compareElements(nodeA as T['element'], nodeB as T['element'], adapter);
+    }
+
+    const aIsText = adapter.isTextNode(nodeA);
+    const bIsText = adapter.isTextNode(nodeB);
+
+    if (aIsText !== bIsText) return false;
+
+    if (aIsText && bIsText) {
+        return (
+            adapter.getTextNodeContent(nodeA as T['textNode']) ===
+            adapter.getTextNodeContent(nodeB as T['textNode'])
+        );
+    }
+
+    const aIsComment = adapter.isCommentNode(nodeA);
+    const bIsComment = adapter.isCommentNode(nodeB);
+
+    if (aIsComment !== bIsComment) return false;
+
+    if (aIsComment && bIsComment) {
+        return (
+            adapter.getCommentNodeContent(nodeA as T['commentNode']) ===
+            adapter.getCommentNodeContent(nodeB as T['commentNode'])
+        );
+    }
+
+    const aIsDoctype = adapter.isDocumentTypeNode(nodeA);
+    const bIsDoctype = adapter.isDocumentTypeNode(nodeB);
+
+    if (aIsDoctype !== bIsDoctype) return false;
+
+    if (aIsDoctype && bIsDoctype) {
+        const nameA = adapter.getDocumentTypeNodeName(nodeA as T['documentType']);
+        const nameB = adapter.getDocumentTypeNodeName(nodeB as T['documentType']);
+        if (nameA !== nameB) return false;
+
+        const pubA = adapter.getDocumentTypeNodePublicId(nodeA as T['documentType']);
+        const pubB = adapter.getDocumentTypeNodePublicId(nodeB as T['documentType']);
+        if (pubA !== pubB) return false;
+
+        const sysA = adapter.getDocumentTypeNodeSystemId(nodeA as T['documentType']);
+        const sysB = adapter.getDocumentTypeNodeSystemId(nodeB as T['documentType']);
+        return sysA === sysB;
+    }
+
+    return compareChildren(nodeA, nodeB, adapter);
+}
+
+function compareElements<T extends TreeAdapterTypeMap>(
+    a: T['element'],
+    b: T['element'],
+    adapter: TreeAdapter<T>,
+): boolean {
+    if (adapter.getTagName(a) !== adapter.getTagName(b)) return false;
+    if (adapter.getNamespaceURI(a) !== adapter.getNamespaceURI(b)) return false;
+
+    if (!areAttributesEqual(adapter.getAttrList(a), adapter.getAttrList(b))) {
+        return false;
+    }
+
+    if (
+        adapter.getTagName(a) === 'template' &&
+        adapter.getNamespaceURI(a) === (NS.HTML as NS)
+    ) {
+        const contentA = adapter.getTemplateContent(a as unknown as T['template']);
+        const contentB = adapter.getTemplateContent(b as unknown as T['template']);
+
+        if (
+            !compareChildren(
+                contentA as unknown as T['node'],
+                contentB as unknown as T['node'],
+                adapter,
+            )
+        ) {
+            return false;
+        }
+    }
+
+    return compareChildren(a as unknown as T['node'], b as unknown as T['node'], adapter);
+}
+
+function compareChildren<T extends TreeAdapterTypeMap>(
+    a: T['node'],
+    b: T['node'],
+    adapter: TreeAdapter<T>,
+): boolean {
+    const childrenA = adapter.getChildNodes(a as unknown as T['parentNode']);
+    const childrenB = adapter.getChildNodes(b as unknown as T['parentNode']);
+
+    if (childrenA.length !== childrenB.length) return false;
+
+    for (let i = 0; i < childrenA.length; i++) {
+        if (
+            !isEqualNode(
+                childrenA[i] as unknown as T['node'],
+                childrenB[i] as unknown as T['node'],
+                adapter,
+            )
+        ) {
+            return false;
+        }
+    }
+
+    return true;
+}
+
+function areAttributesEqual(attrsA: Attribute[], attrsB: Attribute[]): boolean {
+    if (attrsA.length !== attrsB.length) return false;
+
+    for (const a of attrsA) {
+        const match = attrsB.find((b) => attributeMatches(a, b));
+        if (!match) return false;
+    }
+
+    return true;
+}
+
+function attributeMatches(a: Attribute, b: Attribute): boolean {
+    if (a.name !== b.name) return false;
+    if (a.value !== b.value) return false;
+    if ((a.namespace ?? '') !== (b.namespace ?? '')) return false;
+    if ((a.prefix ?? '') !== (b.prefix ?? '')) return false;
+    return true;
+}
