diff --git a/src/schema-parser/base-schema-parsers/prefix-items.ts b/src/schema-parser/base-schema-parsers/prefix-items.ts
new file mode 100644
index 0000000..199b297
--- /dev/null
+++ b/src/schema-parser/base-schema-parsers/prefix-items.ts
@@ -0,0 +1,181 @@
+import { SCHEMA_TYPES } from "../../constants.js";
+import { MonoSchemaParser } from "../mono-schema-parser.js";
+
+export class PrefixItemsSchemaParser extends MonoSchemaParser {
+  override parse() {
+    const {
+      description,
+      prefixItems,
+      items,
+      unevaluatedItems,
+      minItems,
+      maxItems,
+    } = this.schema || {};
+
+    const contentType = this.buildTupleType(
+      prefixItems,
+      items,
+      unevaluatedItems,
+      minItems,
+      maxItems,
+    );
+
+    return {
+      ...(typeof this.schema === "object" ? this.schema : {}),
+      $schemaPath: this.schemaPath.slice(),
+      $parsedSchema: true,
+      schemaType: SCHEMA_TYPES.PRIMITIVE,
+      type: SCHEMA_TYPES.PRIMITIVE,
+      typeIdentifier: this.config.Ts.Keyword.Type,
+      name: this.typeName,
+      description: this.schemaFormatters.formatDescription(description),
+      content: this.schemaUtils.safeAddNullToType(this.schema, contentType),
+    };
+  }
+
+  buildTupleType(
+    prefixItems: any[],
+    items: any,
+    unevaluatedItems: any,
+    minItems: number | undefined,
+    maxItems: number | undefined,
+  ): string {
+    const effectiveItems = this.resolveEffectiveItems(prefixItems, maxItems);
+    const effectiveMinItems = this.resolveEffectiveMinItems(
+      effectiveItems.length,
+      minItems,
+    );
+    const tupleElements = this.buildTupleElements(
+      effectiveItems,
+      effectiveMinItems,
+    );
+    const restSchema = this.resolveRestSchema(items, unevaluatedItems);
+
+    if (restSchema) {
+      const restContent = this.schemaParserFabric
+        .createSchemaParser({
+          schema: restSchema,
+          schemaPath: this.schemaPath,
+        })
+        .getInlineParseContent();
+      return this.config.Ts.TupleWithRest(tupleElements, restContent);
+    }
+
+    return this.config.Ts.Tuple(tupleElements);
+  }
+
+  resolveEffectiveItems(
+    prefixItems: any[],
+    maxItems: number | undefined,
+  ): any[] {
+    if (
+      typeof maxItems === "number" &&
+      maxItems >= 0 &&
+      maxItems < prefixItems.length
+    ) {
+      return prefixItems.slice(0, maxItems);
+    }
+    return prefixItems;
+  }
+
+  resolveEffectiveMinItems(
+    itemCount: number,
+    minItems: number | undefined,
+  ): number {
+    if (typeof minItems === "number" && minItems >= 0) {
+      return Math.min(minItems, itemCount);
+    }
+    return itemCount;
+  }
+
+  buildTupleElements(
+    effectiveItems: any[],
+    effectiveMinItems: number,
+  ): string[] {
+    const tupleElements: string[] = [];
+
+    for (let i = 0; i < effectiveItems.length; i++) {
+      const itemSchema = effectiveItems[i];
+      const elementContent = this.parseElementContent(itemSchema);
+      const label = this.extractLabel(itemSchema);
+      const isOptional = i >= effectiveMinItems;
+
+      if (label && isOptional) {
+        tupleElements.push(
+          this.config.Ts.LabeledOptionalTupleElement(label, elementContent),
+        );
+      } else if (label) {
+        tupleElements.push(
+          this.config.Ts.LabeledTupleElement(label, elementContent),
+        );
+      } else if (isOptional) {
+        tupleElements.push(
+          this.config.Ts.OptionalTupleElement(elementContent),
+        );
+      } else {
+        tupleElements.push(elementContent);
+      }
+    }
+
+    return tupleElements;
+  }
+
+  parseElementContent(itemSchema: any): string {
+    if (itemSchema && typeof itemSchema === "object" && "const" in itemSchema) {
+      return this.formatConstLiteral(itemSchema.const);
+    }
+
+    return this.schemaParserFabric
+      .createSchemaParser({
+        schema: itemSchema,
+        schemaPath: this.schemaPath,
+      })
+      .getInlineParseContent();
+  }
+
+  formatConstLiteral(value: unknown): string {
+    if (typeof value === "string") {
+      return this.config.Ts.StringValue(value);
+    }
+    if (typeof value === "number" || typeof value === "boolean") {
+      return String(value);
+    }
+    if (value === null) {
+      return this.config.Ts.Keyword.Null;
+    }
+    return this.config.Ts.Keyword.Any;
+  }
+
+  extractLabel(itemSchema: any): string | null {
+    if (
+      itemSchema &&
+      typeof itemSchema === "object" &&
+      typeof itemSchema.title === "string" &&
+      itemSchema.title.length > 0
+    ) {
+      const label = itemSchema.title.replace(/[^a-zA-Z0-9_$]/g, "_");
+      if (/^[a-zA-Z_$]/.test(label)) {
+        return label;
+      }
+    }
+    return null;
+  }
+
+  resolveRestSchema(items: any, unevaluatedItems: any): any | null {
+    if (items === false) {
+      return null;
+    }
+    if (items && typeof items === "object" && !Array.isArray(items)) {
+      return items;
+    }
+    if (
+      unevaluatedItems &&
+      typeof unevaluatedItems === "object" &&
+      unevaluatedItems !== false &&
+      !Array.isArray(unevaluatedItems)
+    ) {
+      return unevaluatedItems;
+    }
+    return null;
+  }
+}
