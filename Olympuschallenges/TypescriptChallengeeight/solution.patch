+import type { TreeAdapter, TreeAdapterTypeMap } from '../tree-adapters/interface.js';
+import type { Attribute } from '../common/token.js';
+import { NS } from '../common/html.js';
+
+export function cloneNode<T extends TreeAdapterTypeMap>(
+    node: T['node'],
+    adapter: TreeAdapter<T>,
+    deep: boolean,
+): T['node'] {
+    if (adapter.isElementNode(node)) {
+        return cloneElement(node, adapter, deep);
+    }
+
+    if (adapter.isTextNode(node)) {
+        return adapter.createTextNode(
+            adapter.getTextNodeContent(node),
+        ) as unknown as T['node'];
+    }
+
+    if (adapter.isCommentNode(node)) {
+        return adapter.createCommentNode(
+            adapter.getCommentNodeContent(node),
+        ) as unknown as T['node'];
+    }
+
+    if (adapter.isDocumentTypeNode(node)) {
+        const doc = adapter.createDocument();
+        adapter.setDocumentType(
+            doc,
+            adapter.getDocumentTypeNodeName(node),
+            adapter.getDocumentTypeNodePublicId(node),
+            adapter.getDocumentTypeNodeSystemId(node),
+        );
+        const children = adapter.getChildNodes(doc as unknown as T['parentNode']);
+        if (children.length > 0) {
+            const doctype = children[0];
+            adapter.detachNode(doctype);
+            return doctype as unknown as T['node'];
+        }
+    }
+
+    const fragment = adapter.createDocumentFragment();
+    if (deep) {
+        const children = adapter.getChildNodes(node as unknown as T['parentNode']);
+        for (const child of children) {
+            const clonedChild = cloneNode(child as unknown as T['node'], adapter, true);
+            adapter.appendChild(
+                fragment as unknown as T['parentNode'],
+                clonedChild as unknown as T['childNode'],
+            );
+        }
+    }
+
+    return fragment as unknown as T['node'];
+}
+
+function cloneElement<T extends TreeAdapterTypeMap>(
+    node: T['element'],
+    adapter: TreeAdapter<T>,
+    deep: boolean,
+): T['node'] {
+    const tagName = adapter.getTagName(node);
+    const ns = adapter.getNamespaceURI(node);
+    const attrs = cloneAttributes(adapter.getAttrList(node));
+    const cloned = adapter.createElement(tagName, ns, attrs);
+    const isHtmlTemplate = tagName === 'template' && ns === (NS.HTML as NS);
+
+    if (isHtmlTemplate) {
+        const originalContent = adapter.getTemplateContent(node as unknown as T['template']);
+        const newContent = adapter.createDocumentFragment();
+        adapter.setTemplateContent(cloned as unknown as T['template'], newContent);
+
+        if (deep) {
+            const contentChildren = adapter.getChildNodes(
+                originalContent as unknown as T['parentNode'],
+            );
+            for (const child of contentChildren) {
+                const clonedChild = cloneNode(child as unknown as T['node'], adapter, true);
+                adapter.appendChild(
+                    newContent as unknown as T['parentNode'],
+                    clonedChild as unknown as T['childNode'],
+                );
+            }
+        }
+    }
+
+    if (deep) {
+        const children = adapter.getChildNodes(node as unknown as T['parentNode']);
+        for (const child of children) {
+            const clonedChild = cloneNode(child as unknown as T['node'], adapter, true);
+            adapter.appendChild(
+                cloned as unknown as T['parentNode'],
+                clonedChild as unknown as T['childNode'],
+            );
+        }
+    }
+
+    return cloned as unknown as T['node'];
+}
+
+function cloneAttributes(attrs: Attribute[]): Attribute[] {
+    return attrs.map((attr) => ({ ...attr }));
+}
