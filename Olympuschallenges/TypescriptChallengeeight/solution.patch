+  private detectDiscriminatedUnion(types: Tsoa.Type[]): { propertyName: string; mapping: Record<string, string> } | undefined {
+    const nonNullUndefinedTypes = types.filter(t => {
+      if (t.dataType === 'enum' && t.enums.length === 1 && t.enums[0] === null) {
+        return false;
+      }
+      if (t.dataType === 'undefined') {
+        return false;
+      }
+      return true;
+    });
+
+    if (nonNullUndefinedTypes.length < 2) {
+      return undefined;
+    }
+
+    if (!nonNullUndefinedTypes.every(t => t.dataType === 'refObject')) {
+      return undefined;
+    }
+
+    const refObjectTypes = nonNullUndefinedTypes as Tsoa.RefObjectType[];
+
+    const allPropertySets = refObjectTypes.map(t => new Set(t.properties.map(p => p.name)));
+    const commonPropertyNames = [...allPropertySets[0]].filter(name => allPropertySets.every(set => set.has(name)));
+
+    for (const propName of commonPropertyNames) {
+      const mapping: Record<string, string> = {};
+      let isDiscriminant = true;
+      const seenValues = new Set<string>();
+
+      for (const refObj of refObjectTypes) {
+        const prop = refObj.properties.find(p => p.name === propName);
+        if (!prop || !prop.required) {
+          isDiscriminant = false;
+          break;
+        }
+
+        if (prop.type.dataType !== 'enum') {
+          isDiscriminant = false;
+          break;
+        }
+
+        const enumType = prop.type as Tsoa.EnumType;
+        if (enumType.enums.length !== 1 || typeof enumType.enums[0] !== 'string') {
+          isDiscriminant = false;
+          break;
+        }
+
+        const value = enumType.enums[0] as string;
+        if (seenValues.has(value)) {
+          isDiscriminant = false;
+          break;
+        }
+
+        seenValues.add(value);
+        mapping[value] = refObj.refName;
+      }
+
+      if (isDiscriminant) {
+        return { propertyName: propName, mapping };
+      }
+    }
+
+    return undefined;
+  }
 }
