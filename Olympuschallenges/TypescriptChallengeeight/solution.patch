--- /dev/null
+++ b/packages/parse5/lib/tree-utils/walk.ts
@@ -0,0 +1,107 @@
+import type { TreeAdapter, TreeAdapterTypeMap } from '../tree-adapters/interface.js';
+import { NS } from '../common/html.js';
+
+export enum WalkerAction {
+    SKIP = 'SKIP',
+    STOP = 'STOP',
+}
+
+export interface WalkerVisitor<T extends TreeAdapterTypeMap> {
+    enter?: (node: T['node']) => WalkerAction | void;
+    leave?: (node: T['node']) => void;
+}
+
+export function walk<T extends TreeAdapterTypeMap>(
+    root: T['node'],
+    adapter: TreeAdapter<T>,
+    visitor: WalkerVisitor<T>,
+): void {
+    walkNode(root, adapter, visitor);
+}
+
+function isLeafNode<T extends TreeAdapterTypeMap>(
+    node: T['node'],
+    adapter: TreeAdapter<T>,
+): boolean {
+    return adapter.isTextNode(node) || adapter.isCommentNode(node) || adapter.isDocumentTypeNode(node);
+}
+
+function walkNode<T extends TreeAdapterTypeMap>(
+    node: T['node'],
+    adapter: TreeAdapter<T>,
+    visitor: WalkerVisitor<T>,
+): boolean {
+    const action = visitor.enter?.(node);
+
+    if (action === WalkerAction.STOP) {
+        return true;
+    }
+
+    if (action !== WalkerAction.SKIP) {
+        if (adapter.isElementNode(node)) {
+            if (
+                adapter.getTagName(node) === 'template' &&
+                adapter.getNamespaceURI(node) === (NS.HTML as NS)
+            ) {
+                const content = adapter.getTemplateContent(node as unknown as T['template']);
+                if (walkNode(content as unknown as T['node'], adapter, visitor)) {
+                    return true;
+                }
+            }
+
+            const children = adapter.getChildNodes(node as unknown as T['parentNode']);
+            for (const child of children) {
+                if (walkNode(child as unknown as T['node'], adapter, visitor)) {
+                    return true;
+                }
+            }
+        } else if (!isLeafNode(node, adapter)) {
+            const children = adapter.getChildNodes(node as unknown as T['parentNode']);
+            for (const child of children) {
+                if (walkNode(child as unknown as T['node'], adapter, visitor)) {
+                    return true;
+                }
+            }
+        }
+    }
+
+    visitor.leave?.(node);
+    return false;
+}
+
+export function findNode<T extends TreeAdapterTypeMap>(
+    root: T['node'],
+    adapter: TreeAdapter<T>,
+    predicate: (node: T['node']) => boolean,
+): T['node'] | null {
+    let result: T['node'] | null = null;
+
+    walk(root, adapter, {
+        enter(node) {
+            if (predicate(node)) {
+                result = node;
+                return WalkerAction.STOP;
+            }
+        },
+    });
+
+    return result;
+}
+
+export function findAllNodes<T extends TreeAdapterTypeMap>(
+    root: T['node'],
+    adapter: TreeAdapter<T>,
+    predicate: (node: T['node']) => boolean,
+): T['node'][] {
+    const results: T['node'][] = [];
+
+    walk(root, adapter, {
+        enter(node) {
+            if (predicate(node)) {
+                results.push(node);
+            }
+        },
+    });
+
+    return results;
+}
