+  }
+
+  static fromPolicy(
+    policy: RetryPolicy,
+    strategy: BackoffStrategy = exponentialBackoff,
+    hooks: RetryHooks = {},
+  ): RetryExecutor {
+    return new RetryExecutor(policy, strategy, hooks)
+  }
+}
+
+export class RetryPolicyBuilder {
+  private maxRetries: number = DEFAULT_RETRY_POLICY.maxRetries
+  private baseDelayMs: number = DEFAULT_RETRY_POLICY.baseDelayMs
+  private maxDelayMs: number = DEFAULT_RETRY_POLICY.maxDelayMs
+  private retryableStatuses: Set<number> = new Set(DEFAULT_RETRY_POLICY.retryableStatuses)
+
+  withMaxRetries(maxRetries: number): this {
+    this.maxRetries = maxRetries
+    return this
+  }
+
+  withBaseDelay(ms: number): this {
+    this.baseDelayMs = ms
+    return this
+  }
+
+  withMaxDelay(ms: number): this {
+    this.maxDelayMs = ms
+    return this
+  }
+
+  withRetryableStatuses(statuses: Iterable<number>): this {
+    this.retryableStatuses = new Set(statuses)
+    return this
+  }
+
+  addRetryableStatus(status: number): this {
+    this.retryableStatuses.add(status)
+    return this
+  }
+
+  removeRetryableStatus(status: number): this {
+    this.retryableStatuses.delete(status)
+    return this
+  }
+
+  build(): RetryPolicy {
+    return {
+      maxRetries: this.maxRetries,
+      baseDelayMs: this.baseDelayMs,
+      maxDelayMs: this.maxDelayMs,
+      retryableStatuses: new Set(this.retryableStatuses),
+    }
+  }
