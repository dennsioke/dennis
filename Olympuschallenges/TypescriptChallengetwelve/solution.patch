@@ -0,0 +1,352 @@
+import { ResponseError, sleep } from './utils.js'
+
+export const RETRYABLE_STATUS_CODES: ReadonlySet<number> = new Set([429, 502, 503, 504])
+
+export interface RetryPolicy {
+  readonly maxRetries: number
+  readonly baseDelayMs: number
+  readonly maxDelayMs: number
+  readonly retryableStatuses: ReadonlySet<number>
+}
+
+export interface RetryContext {
+  readonly attempt: number
+  readonly delay: number
+  readonly error: unknown
+  readonly totalElapsedMs: number
+}
+
+export interface RetryHooks {
+  readonly onRetry?: (ctx: RetryContext) => void
+  readonly onExhausted?: (totalAttempts: number, lastError: unknown) => void
+  readonly onSuccess?: (attempt: number, totalElapsedMs: number) => void
+}
+
+export type BackoffStrategy = (attempt: number, policy: RetryPolicy) => number
+
+export const exponentialBackoff: BackoffStrategy = (attempt, policy) =>
+  Math.min(Math.pow(2, attempt) * policy.baseDelayMs, policy.maxDelayMs)
+
+export const linearBackoff: BackoffStrategy = (attempt, policy) =>
+  Math.min((attempt + 1) * policy.baseDelayMs, policy.maxDelayMs)
+
+export const constantBackoff: BackoffStrategy = (_attempt, policy) => policy.baseDelayMs
+
+export const DEFAULT_RETRY_POLICY: RetryPolicy = {
+  maxRetries: 0,
+  baseDelayMs: 1000,
+  maxDelayMs: 30000,
+  retryableStatuses: RETRYABLE_STATUS_CODES,
+}
+
+export const RetryPolicyPresets = {
+  aggressive: {
+    maxRetries: 5,
+    baseDelayMs: 500,
+    maxDelayMs: 15000,
+    retryableStatuses: RETRYABLE_STATUS_CODES,
+  } as RetryPolicy,
+  conservative: {
+    maxRetries: 2,
+    baseDelayMs: 2000,
+    maxDelayMs: 30000,
+    retryableStatuses: RETRYABLE_STATUS_CODES,
+  } as RetryPolicy,
+  none: {
+    maxRetries: 0,
+    baseDelayMs: 1000,
+    maxDelayMs: 30000,
+    retryableStatuses: RETRYABLE_STATUS_CODES,
+  } as RetryPolicy,
+} as const
+
+export function buildRetryPolicy(retries: number | undefined): RetryPolicy {
+  return {
+    maxRetries: retries ?? 0,
+    baseDelayMs: DEFAULT_RETRY_POLICY.baseDelayMs,
+    maxDelayMs: DEFAULT_RETRY_POLICY.maxDelayMs,
+    retryableStatuses: DEFAULT_RETRY_POLICY.retryableStatuses,
+  }
+}
+
+export function isRetryableError(error: unknown, policy: RetryPolicy): boolean {
+  return error instanceof ResponseError && policy.retryableStatuses.has(error.status_code)
+}
+
+export class RetryError extends Error {
+  constructor(
+    public readonly cause: unknown,
+    public readonly totalAttempts: number,
+  ) {
+    super(cause instanceof Error ? cause.message : String(cause))
+    this.name = 'RetryError'
+    if (Error.captureStackTrace) {
+      Error.captureStackTrace(this, RetryError)
+    }
+  }
+}
+
+export class RetryState {
+  private _attempt: number = 0
+  private readonly _delays: number[] = []
+  private readonly _startTime: number = Date.now()
+
+  constructor(private readonly policy: RetryPolicy) {}
+
+  get attempt(): number {
+    return this._attempt
+  }
+
+  get delays(): ReadonlyArray<number> {
+    return this._delays
+  }
+
+  get totalAttempts(): number {
+    return this._attempt + 1
+  }
+
+  get elapsedMs(): number {
+    return Date.now() - this._startTime
+  }
+
+  get isExhausted(): boolean {
+    return this._attempt >= this.policy.maxRetries
+  }
+
+  get hasRetries(): boolean {
+    return this._attempt < this.policy.maxRetries
+  }
+
+  get remaining(): number {
+    return Math.max(0, this.policy.maxRetries - this._attempt)
+  }
+
+  computeDelay(strategy: BackoffStrategy = exponentialBackoff): number {
+    return strategy(this._attempt, this.policy)
+  }
+
+  advance(delay: number): void {
+    this._delays.push(delay)
+    this._attempt++
+  }
+
+  isRetryable(error: unknown): boolean {
+    return isRetryableError(error, this.policy)
+  }
+}
+
+export class RetryMonitor {
+  private _totalRequests: number = 0
+  private _totalRetries: number = 0
+  private _totalFailures: number = 0
+  private _totalSuccesses: number = 0
+
+  get totalRequests(): number {
+    return this._totalRequests
+  }
+
+  get totalRetries(): number {
+    return this._totalRetries
+  }
+
+  get totalFailures(): number {
+    return this._totalFailures
+  }
+
+  get totalSuccesses(): number {
+    return this._totalSuccesses
+  }
+
+  get retryRate(): number {
+    return this._totalRequests === 0 ? 0 : this._totalRetries / this._totalRequests
+  }
+
+  recordRequest(): void {
+    this._totalRequests++
+  }
+
+  recordRetry(): void {
+    this._totalRetries++
+  }
+
+  recordFailure(): void {
+    this._totalFailures++
+  }
+
+  recordSuccess(): void {
+    this._totalSuccesses++
+  }
+
+  reset(): void {
+    this._totalRequests = 0
+    this._totalRetries = 0
+    this._totalFailures = 0
+    this._totalSuccesses = 0
+  }
+
+  getStats(): {
+    totalRequests: number
+    totalRetries: number
+    totalFailures: number
+    totalSuccesses: number
+    retryRate: number
+  } {
+    return {
+      totalRequests: this._totalRequests,
+      totalRetries: this._totalRetries,
+      totalFailures: this._totalFailures,
+      totalSuccesses: this._totalSuccesses,
+      retryRate: this.retryRate,
+    }
+  }
+
+  toHooks(): RetryHooks {
+    return {
+      onRetry: () => this.recordRetry(),
+      onExhausted: () => this.recordFailure(),
+      onSuccess: () => this.recordSuccess(),
+    }
+  }
+}
+
+export class RetryExecutor {
+  private readonly policy: RetryPolicy
+  private readonly strategy: BackoffStrategy
+  private readonly hooks: RetryHooks
+
+  constructor(
+    policy: RetryPolicy,
+    strategy: BackoffStrategy = exponentialBackoff,
+    hooks: RetryHooks = {},
+  ) {
+    this.policy = policy
+    this.strategy = strategy
+    this.hooks = hooks
+  }
+
+  async execute(fn: () => Promise<Response>, signal?: AbortSignal): Promise<Response> {
+    const state = new RetryState(this.policy)
+    this.hooks.onRetry
+
+    while (true) {
+      try {
+        const result = await fn()
+        if (this.hooks.onSuccess) {
+          this.hooks.onSuccess(state.attempt, state.elapsedMs)
+        }
+        return result
+      } catch (error) {
+        if (!state.isRetryable(error) || state.isExhausted) {
+          if (this.hooks.onExhausted) {
+            this.hooks.onExhausted(state.totalAttempts, error)
+          }
+          throw error
+        }
+
+        const delay = state.computeDelay(this.strategy)
+
+        if (this.hooks.onRetry) {
+          this.hooks.onRetry({
+            attempt: state.attempt,
+            delay,
+            error,
+            totalElapsedMs: state.elapsedMs,
+          })
+        }
+
+        state.advance(delay)
+        await sleep(delay, signal)
+      }
+    }
+  }
+
+  withHooks(hooks: RetryHooks): RetryExecutor {
+    return new RetryExecutor(this.policy, this.strategy, {
+      ...this.hooks,
+      ...hooks,
+    })
+  }
+
+  withStrategy(strategy: BackoffStrategy): RetryExecutor {
+    return new RetryExecutor(this.policy, strategy, this.hooks)
+  }
+
+  withMonitor(monitor: RetryMonitor): RetryExecutor {
+    const monitorHooks = monitor.toHooks()
