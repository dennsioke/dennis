index 0000000..2e6f16e
--- /dev/null
+++ b/src/retry.ts
@@ -0,0 +1,40 @@
+import { ResponseError, sleep } from './utils.js'
+
+export const RETRYABLE_STATUS_CODES: ReadonlySet<number> = new Set([429, 502, 503, 504])
+
+const BASE_DELAY_MS = 1000
+const MAX_DELAY_MS = 30000
+
+function computeDelay(attempt: number): number {
+  return Math.min(Math.pow(2, attempt) * BASE_DELAY_MS, MAX_DELAY_MS)
+}
+
+export class RetryExecutor {
+  private readonly maxRetries: number
+
+  constructor(maxRetries: number) {
+    this.maxRetries = maxRetries
+  }
+
+  async execute(fn: () => Promise<Response>, signal?: AbortSignal): Promise<Response> {
+    let attempt = 0
+    while (true) {
+      try {
+        return await fn()
+      } catch (error) {
+        const isRetryable =
+          error instanceof ResponseError && RETRYABLE_STATUS_CODES.has(error.status_code)
+        if (!isRetryable || attempt >= this.maxRetries) {
+          throw error
+        }
+        const delay = computeDelay(attempt)
+        await sleep(delay, signal)
+        attempt++
+      }
+    }
+  }
+
+  static fromRetries(retries: number | undefined): RetryExecutor {
+    return new RetryExecutor(retries ?? 0)
+  }
+}
