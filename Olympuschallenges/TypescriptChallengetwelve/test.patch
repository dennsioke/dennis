diff --git a/test.sh b/test.sh
new file mode 100755
index 0000000..ced4ef8
--- /dev/null
+++ b/test.sh
@@ -0,0 +1,38 @@
+#!/usr/bin/env bash
+set -euo pipefail
+
+OUTPUT_PATH=""
+MODE=""
+
+while [[ $# -gt 0 ]]; do
+  case "$1" in
+    --output_path)
+      OUTPUT_PATH="$2"
+      shift 2
+      ;;
+    base|new)
+      MODE="$1"
+      shift
+      ;;
+    *)
+      echo "Usage: $0 --output_path <path> [base|new]" >&2
+      exit 1
+      ;;
+  esac
+done
+
+MODE="${MODE:-new}"
+
+REPORTER_ARGS=()
+if [[ -n "$OUTPUT_PATH" ]]; then
+  REPORTER_ARGS=(--reporter=junit --outputFile="$OUTPUT_PATH")
+fi
+
+if [ "$MODE" = "base" ]; then
+  npx vitest --run "${REPORTER_ARGS[@]}" test/index.test.ts test/utils.test.ts test/browser.test.ts
+elif [ "$MODE" = "new" ]; then
+  npx vitest --run "${REPORTER_ARGS[@]}" test/retry.test.ts
+else
+  echo "Usage: $0 --output_path <path> [base|new]" >&2
+  exit 1
+fi
diff --git a/test/retry.test.ts b/test/retry.test.ts
new file mode 100644
index 0000000..26d00e4
--- /dev/null
+++ b/test/retry.test.ts
@@ -0,0 +1,252 @@
+import { describe, it, expect, vi, beforeEach, afterEach } from 'vitest'
+import { Ollama } from '../src/browser'
+import type { GenerateResponse } from '../src/interfaces'
+
+function makeStreamBody(chunks: object[]): ReadableStream<Uint8Array> {
+  const encoder = new TextEncoder()
+  return new ReadableStream({
+    start(controller) {
+      for (const chunk of chunks) {
+        controller.enqueue(encoder.encode(JSON.stringify(chunk) + '\n'))
+      }
+      controller.close()
+    },
+  })
+}
+
+function makeResponse(status: number, body: object): Response {
+  return new Response(JSON.stringify(body), {
+    status,
+    headers: { 'content-type': 'application/json' },
+  })
+}
+
+const successBody: GenerateResponse = {
+  model: 'llama2',
+  created_at: new Date(),
+  done: true,
+  done_reason: 'stop',
+  context: [],
+  total_duration: 0,
+  load_duration: 0,
+  prompt_eval_count: 0,
+  prompt_eval_duration: 0,
+  eval_count: 0,
+  eval_duration: 0,
+}
+
+describe('retry with exponential backoff', () => {
+  beforeEach(() => {
+    vi.useFakeTimers()
+  })
+
+  afterEach(() => {
+    vi.useRealTimers()
+  })
+
+  it('retries on 503 and succeeds on the third attempt', async () => {
+    let calls = 0
+    const mockFetch = vi.fn().mockImplementation(() => {
+      calls++
+      if (calls < 3) {
+        return Promise.resolve(makeResponse(503, { error: 'service unavailable' }))
+      }
+      return Promise.resolve(makeResponse(200, successBody))
+    })
+
+    const client = new Ollama({ fetch: mockFetch as any, retries: 3 })
+    const promise = client.generate({ model: 'llama2', prompt: 'test' })
+    await vi.runAllTimersAsync()
+    const result = await promise
+
+    expect(calls).toBe(3)
+    expect(result.done).toBe(true)
+  })
+
+  it('retries on 429, 502, and 504', async () => {
+    for (const status of [429, 502, 504]) {
+      let calls = 0
+      const mockFetch = vi.fn().mockImplementation(() => {
+        calls++
+        if (calls === 1) return Promise.resolve(makeResponse(status, { error: 'transient' }))
+        return Promise.resolve(makeResponse(200, successBody))
+      })
+
+      const client = new Ollama({ fetch: mockFetch as any, retries: 1 })
+      const p = client.generate({ model: 'llama2', prompt: 'test' })
+      await vi.runAllTimersAsync()
+      await p
+
+      expect(calls).toBe(2)
+    }
+  })
+
+  it('does not retry on 400, 404, or 500', async () => {
+    for (const status of [400, 404, 500]) {
+      let calls = 0
+      const mockFetch = vi.fn().mockImplementation(() => {
+        calls++
+        return Promise.resolve(makeResponse(status, { error: 'error' }))
+      })
+
+      const client = new Ollama({ fetch: mockFetch as any, retries: 3 })
+      await expect(client.generate({ model: 'llama2', prompt: 'test' })).rejects.toThrow()
+      expect(calls).toBe(1)
+    }
+  })
+
+  it('waits 1000ms before first retry and 2000ms before second', async () => {
+    const callTimes: number[] = []
+    const mockFetch = vi.fn().mockImplementation(() => {
+      callTimes.push(Date.now())
+      return Promise.resolve(makeResponse(503, { error: 'service unavailable' }))
+    })
+
+    const client = new Ollama({ fetch: mockFetch as any, retries: 2 })
+    const promise = client.generate({ model: 'llama2', prompt: 'test' }).catch(() => {})
+    await vi.runAllTimersAsync()
+    await promise
+
+    expect(callTimes).toHaveLength(3)
+    expect(callTimes[1] - callTimes[0]).toBe(1000)
+    expect(callTimes[2] - callTimes[1]).toBe(2000)
+  })
+
+  it('caps backoff delay at 30000ms', async () => {
+    const callTimes: number[] = []
+    const mockFetch = vi.fn().mockImplementation(() => {
+      callTimes.push(Date.now())
+      return Promise.resolve(makeResponse(503, { error: 'service unavailable' }))
+    })
+
+    const client = new Ollama({ fetch: mockFetch as any, retries: 6 })
+    const promise = client.generate({ model: 'llama2', prompt: 'test' }).catch(() => {})
+    await vi.runAllTimersAsync()
+    await promise
+
+    expect(callTimes).toHaveLength(7)
+    expect(callTimes[6] - callTimes[5]).toBe(30000)
+  })
+
+  it('throws last error when retries are exhausted', async () => {
+    const mockFetch = vi.fn().mockImplementation(() =>
+      Promise.resolve(makeResponse(503, { error: 'service unavailable' })),
+    )
+
+    const client = new Ollama({ fetch: mockFetch as any, retries: 2 })
+    const promise = client.generate({ model: 'llama2', prompt: 'test' })
+    const rejection = expect(promise).rejects.toThrow('service unavailable')
+    await vi.runAllTimersAsync()
+    await rejection
+    expect(mockFetch).toHaveBeenCalledTimes(3)
+  })
+
+  it('does not retry when retries is 0', async () => {
+    const mockFetch = vi.fn().mockResolvedValue(
+      makeResponse(503, { error: 'service unavailable' }),
+    )
+
+    const client = new Ollama({ fetch: mockFetch as any, retries: 0 })
+    await expect(client.generate({ model: 'llama2', prompt: 'test' })).rejects.toThrow()
+    expect(mockFetch).toHaveBeenCalledTimes(1)
+  })
+
+  it('retries streaming request and returns a working iterator after retry', async () => {
+    let calls = 0
+    const mockFetch = vi.fn().mockImplementation(() => {
+      calls++
+      if (calls < 2) {
+        return Promise.resolve(makeResponse(503, { error: 'service unavailable' }))
+      }
+      return Promise.resolve(
+        new Response(
+          makeStreamBody([
+            {
+              model: 'llama2',
+              created_at: new Date().toISOString(),
+              response: 'hello',
+              done: false,
+            },
+            {
+              model: 'llama2',
+              created_at: new Date().toISOString(),
+              response: '',
+              done: true,
+              done_reason: 'stop',
+              context: [],
+              total_duration: 0,
+              load_duration: 0,
+              prompt_eval_count: 0,
+              prompt_eval_duration: 0,
+              eval_count: 0,
+              eval_duration: 0,
+            },
+          ]),
+          { status: 200 },
+        ),
+      )
+    })
+
+    const client = new Ollama({ fetch: mockFetch as any, retries: 2 })
+    const promise = client.generate({ model: 'llama2', prompt: 'test', stream: true })
+    await vi.runAllTimersAsync()
+    const itr = await promise
+
+    const chunks: GenerateResponse[] = []
+    for await (const chunk of itr) {
+      chunks.push(chunk)
+    }
+
+    expect(calls).toBe(2)
+    expect(chunks[0].response).toBe('hello')
+    expect(chunks[chunks.length - 1].done).toBe(true)
+  })
+
+  it('abort during streaming retry backoff cancels pending retry', async () => {
+    let calls = 0
+    const mockFetch = vi.fn().mockImplementation(() => {
+      calls++
+      return Promise.resolve(makeResponse(503, { error: 'service unavailable' }))
+    })
+
+    const client = new Ollama({ fetch: mockFetch as any, retries: 5 })
+    const promise = client.generate({ model: 'llama2', prompt: 'test', stream: true })
+    const rejection = expect(promise).rejects.toThrow()
+
+    await vi.advanceTimersByTimeAsync(500)
+    client.abort()
+    await vi.runAllTimersAsync()
+
+    await rejection
+    expect(calls).toBe(1)
+  })
+
+  it('abort during non-streaming retry backoff cancels pending retry', async () => {
+    let calls = 0
+    const mockFetch = vi.fn().mockImplementation(() => {
+      calls++
+      return Promise.resolve(makeResponse(503, { error: 'service unavailable' }))
+    })
+
+    const client = new Ollama({ fetch: mockFetch as any, retries: 5 })
+    const promise = client.generate({ model: 'llama2', prompt: 'test' })
+    const rejection = expect(promise).rejects.toThrow()
+
+    await vi.advanceTimersByTimeAsync(500)
+    client.abort()
+    await vi.runAllTimersAsync()
+
+    await rejection
+    expect(calls).toBe(1)
+  })
+
+  it('does not retry when no retries option is configured', async () => {
+    const mockFetch = vi.fn().mockResolvedValue(
+      makeResponse(503, { error: 'service unavailable' }),
+    )
+
+    const client = new Ollama({ fetch: mockFetch as any })
+    await expect(client.generate({ model: 'llama2', prompt: 'test' })).rejects.toThrow()
+    expect(mockFetch).toHaveBeenCalledTimes(1)
+  })
+})
