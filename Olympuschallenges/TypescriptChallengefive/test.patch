+#!/usr/bin/env bash
+set -euo pipefail
+
+OUTPUT_PATH=""
+MODE=""
+
+while [[ $# -gt 0 ]]; do
+  case "$1" in
+    --output_path)
+      OUTPUT_PATH="$2"
+      shift 2
+      ;;
+    base|new)
+      MODE="$1"
+      shift
+      ;;
+    *)
+      echo "Usage: $0 [--output_path <path>] <base|new>" >&2
+      exit 1
+      ;;
+  esac
+done
+
+MODE="${MODE:-new}"
+
+REPORTER_ARGS=("--reporter=verbose")
+if [ -n "$OUTPUT_PATH" ]; then
+  REPORTER_ARGS+=("--reporter=junit" "--outputFile.junit=$OUTPUT_PATH")
+fi
+
+if [ "$MODE" = "base" ]; then
+  node_modules/.bin/vitest run "${REPORTER_ARGS[@]}" \
+    src/__tests__/core/model.test.tsx \
+    src/__tests__/core/engine.integration.test.ts \
+    src/__tests__/core/helpers.test.tsx \
+    src/__tests__/core/index.integration.test.tsx \
+    src/__tests__/navigation/context.test.tsx \
+    src/__tests__/navigation/link.test.tsx \
+    src/__tests__/navigation/withNavigationContext.test.tsx \
+    src/__tests__/navigation/withNavigationHandlers.test.tsx
+elif [ "$MODE" = "new" ]; then
+  node_modules/.bin/vitest run "${REPORTER_ARGS[@]}" \
+    src/__tests__/core/autoplay.test.tsx
+else
+  echo "Usage: $0 [--output_path <path>] <base|new>" >&2
+  exit 1
+fi
