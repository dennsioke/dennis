--- /dev/null
+++ b/src/core/autoplay.ts
@@ -0,0 +1,328 @@
+import type { CtxLike, SliderPropsLike } from './model';
+export type AutoplayDirection = 'next' | 'prev';
+export type AutoplayState = 'idle' | 'scheduled' | 'paused';
+export type AutoplayEventMap = {
+  stateChange: { prev: AutoplayState; next: AutoplayState };
+  tick: { index: number; direction: AutoplayDirection };
+  terminalReached: { index: number; direction: AutoplayDirection };
+  directionChange: { prev: AutoplayDirection; next: AutoplayDirection };
+};
+export type AutoplayEventType = keyof AutoplayEventMap;
+export type AutoplayEvent<T extends AutoplayEventType = AutoplayEventType> = {
+  type: T;
+} & AutoplayEventMap[T];
+export type AutoplayEventListener<T extends AutoplayEventType = AutoplayEventType> = (
+  event: AutoplayEvent<T>
+) => void;
+export type AutoplayPropsLike = SliderPropsLike & {
+  autoplay?: boolean;
+  autoplayDirection?: AutoplayDirection;
+  autoplayInterval?: number;
+  autoplaySpeed?: number;
+  pauseOnVisibilityChange?: boolean;
+  onAutoplayStateChange?: ((state: AutoplayState) => void) | null;
+};
+export type AutoplayCtxLike = Omit<CtxLike, 'props'> & {
+  props: AutoplayPropsLike;
+  autoplayPaused: boolean;
+  autoplayTimer: ReturnType<typeof setTimeout> | null;
+  autoplayState: AutoplayState;
+  autoplayListeners: Map<AutoplayEventType, Set<AutoplayEventListener<any>>>;
+  autoplayLastDirection: AutoplayDirection;
+};
+export interface AutoplayController {
+  schedule: () => void;
+  cancel: () => void;
+  play: () => void;
+  pause: () => void;
+  getState: () => AutoplayState;
+  getEffectiveDuration: () => number;
+  getDirection: () => AutoplayDirection;
+  isAtTerminal: () => boolean;
+  computeNext: () => number | null;
+  getProgress: () => AutoplayProgress;
+  subscribe: <T extends AutoplayEventType>(
+    type: T,
+    listener: AutoplayEventListener<T>
+  ) => () => void;
+  dispose: () => void;
+}
+export type AutoplayProgress = {
+  state: AutoplayState;
+  direction: AutoplayDirection;
+  currentIndex: number;
+  totalSlides: number;
+  effectiveDuration: number;
+  isTerminal: boolean;
+  infinite: boolean;
+};
+const DEFAULT_INTERVAL = 3000;
+const DEFAULT_SPEED = 1;
+const MIN_INTERVAL = 50;
+function clampInterval(ms: number): number {
+  if (!Number.isFinite(ms) || ms < MIN_INTERVAL) return MIN_INTERVAL;
+  return Math.round(ms);
+}
+function resolveBaseInterval(ctx: AutoplayCtxLike): number {
+  if (ctx.index !== null && ctx.media) {
+    const item = ctx.media[ctx.index];
+    if (item && typeof item.duration === 'number' && item.duration > 0) {
+      return item.duration;
+    }
+  }
+  return ctx.props.autoplayInterval ?? DEFAULT_INTERVAL;
+}
+function resolveSpeed(ctx: AutoplayCtxLike): number {
+  const speed = ctx.props.autoplaySpeed ?? DEFAULT_SPEED;
+  if (!Number.isFinite(speed) || speed <= 0) return DEFAULT_SPEED;
+  return speed;
+}
+export function resolveEffectiveDuration(ctx: AutoplayCtxLike): number {
+  return clampInterval(resolveBaseInterval(ctx) / resolveSpeed(ctx));
+}
+export function resolveDirection(ctx: AutoplayCtxLike): AutoplayDirection {
+  return ctx.props.autoplayDirection === 'prev' ? 'prev' : 'next';
+}
+export function isAtTerminalSlide(
+  ctx: AutoplayCtxLike,
+  direction: AutoplayDirection
+): boolean {
+  if (!ctx.media || ctx.media.length === 0) return true;
+  if (ctx.index === null) return true;
+  if (direction === 'next') return ctx.index >= ctx.media.length - 1;
+  return ctx.index <= 0;
+}
+export function computeNextIndex(
+  currentIndex: number,
+  mediaLength: number,
+  direction: AutoplayDirection,
+  infinite: boolean
+): number | null {
+  if (mediaLength <= 0) return null;
+  if (direction === 'next') {
+    const next = currentIndex + 1;
+    if (next < mediaLength) return next;
+    return infinite ? 0 : null;
+  }
+  const prev = currentIndex - 1;
+  if (prev >= 0) return prev;
+  return infinite ? mediaLength - 1 : null;
+}
+function canAutoplay(ctx: AutoplayCtxLike): boolean {
+  if (!ctx._mounted) return false;
+  if (!ctx.props.autoplay) return false;
+  if (ctx.autoplayPaused) return false;
+  if (!ctx.started) return false;
+  if (ctx.props.disabled) return false;
+  if (!ctx.media || ctx.media.length <= 1) return false;
+  return true;
+}
+function getListenerSet<T extends AutoplayEventType>(
+  ctx: AutoplayCtxLike,
+  type: T
+): Set<AutoplayEventListener<T>> {
+  let set = ctx.autoplayListeners.get(type);
+  if (!set) {
+    set = new Set();
+    ctx.autoplayListeners.set(type, set);
+  }
+  return set as Set<AutoplayEventListener<T>>;
+}
+function emitEvent<T extends AutoplayEventType>(
+  ctx: AutoplayCtxLike,
+  type: T,
+  payload: AutoplayEventMap[T]
+): void {
+  const set = ctx.autoplayListeners.get(type);
+  if (!set || set.size === 0) return;
+  const event = { type, ...payload } as AutoplayEvent<T>;
+  for (const listener of set) {
+    (listener as AutoplayEventListener<T>)(event);
+  }
+}
+function transitionState(ctx: AutoplayCtxLike, next: AutoplayState): void {
+  const prev = ctx.autoplayState;
+  if (prev === next) return;
+  ctx.autoplayState = next;
+  emitEvent(ctx, 'stateChange', { prev, next });
+  if (ctx.props.onAutoplayStateChange) {
+    ctx.props.onAutoplayStateChange(next);
+  }
+}
+function trackDirectionChange(ctx: AutoplayCtxLike): void {
+  const current = resolveDirection(ctx);
+  if (ctx.autoplayLastDirection !== current) {
+    const prev = ctx.autoplayLastDirection;
+    ctx.autoplayLastDirection = current;
+    emitEvent(ctx, 'directionChange', { prev, next: current });
+  }
+}
+type VisibilityCleanup = () => void;
+function attachVisibilityObserver(
+  onHidden: () => void,
+  onVisible: () => void
+): VisibilityCleanup {
+  if (typeof document === 'undefined') return () => {};
+  const handler = () => {
+    if (document.hidden) onHidden();
+    else onVisible();
+  };
+  document.addEventListener('visibilitychange', handler);
+  return () => document.removeEventListener('visibilitychange', handler);
+}
+export function createAutoplay(
+  getCtx: () => AutoplayCtxLike,
+  advance: (args: { index: number; direction: boolean }) => void
+): AutoplayController {
+  let visibilityCleanup: VisibilityCleanup | null = null;
+  let wasScheduledBeforeHidden = false;
+  const cancel = (): void => {
+    const ctx = getCtx();
+    if (ctx.autoplayTimer !== null) {
+      clearTimeout(ctx.autoplayTimer);
+      ctx._timeouts?.delete?.(ctx.autoplayTimer);
+      ctx.autoplayTimer = null;
+    }
+  };
+  const schedule = (): void => {
+    const ctx = getCtx();
+    cancel();
+    if (!canAutoplay(ctx)) return;
+    trackDirectionChange(ctx);
+    const direction = resolveDirection(ctx);
+    const infinite = ctx.props.infinite !== false;
+    if (!infinite && isAtTerminalSlide(ctx, direction)) {
+      emitEvent(ctx, 'terminalReached', {
+        index: ctx.index ?? 0,
+        direction,
+      });
+      transitionState(ctx, 'idle');
+      return;
+    }
+    const duration = resolveEffectiveDuration(ctx);
+    transitionState(ctx, 'scheduled');
+    const timerId = ctx._setTimeout(() => {
+      const c = getCtx();
+      c.autoplayTimer = null;
+      if (!canAutoplay(c)) {
+        transitionState(c, 'idle');
+        return;
+      }
+      const dir = resolveDirection(c);
+      const inf = c.props.infinite !== false;
+      const nextIdx = computeNextIndex(
+        c.index ?? 0,
+        c.media?.length ?? 0,
+        dir,
+        inf
+      );
+      if (nextIdx === null) {
+        emitEvent(c, 'terminalReached', {
+          index: c.index ?? 0,
+          direction: dir,
+        });
+        transitionState(c, 'idle');
+        return;
+      }
+      emitEvent(c, 'tick', { index: nextIdx, direction: dir });
+      advance({ index: nextIdx, direction: dir === 'next' });
+    }, duration);
+    ctx.autoplayTimer = timerId;
+  };
+  const play = (): void => {
+    const ctx = getCtx();
+    ctx.autoplayPaused = false;
+    schedule();
+  };
+  const pause = (): void => {
+    const ctx = getCtx();
+    ctx.autoplayPaused = true;
+    cancel();
+    transitionState(ctx, 'paused');
+  };
+  const getState = (): AutoplayState => getCtx().autoplayState;
+  const getEffectiveDurationFn = (): number => resolveEffectiveDuration(getCtx());
+  const getDirectionFn = (): AutoplayDirection => resolveDirection(getCtx());
+  const isAtTerminalFn = (): boolean => {
+    const ctx = getCtx();
+    return isAtTerminalSlide(ctx, resolveDirection(ctx));
+  };
+  const computeNext = (): number | null => {
+    const ctx = getCtx();
+    if (!ctx.media || ctx.index === null) return null;
+    return computeNextIndex(
+      ctx.index,
+      ctx.media.length,
+      resolveDirection(ctx),
+      ctx.props.infinite !== false
+    );
+  };
+  const getProgress = (): AutoplayProgress => {
+    const ctx = getCtx();
+    const direction = resolveDirection(ctx);
+    return {
+      state: ctx.autoplayState,
+      direction,
+      currentIndex: ctx.index ?? 0,
+      totalSlides: ctx.media?.length ?? 0,
+      effectiveDuration: resolveEffectiveDuration(ctx),
+      isTerminal: isAtTerminalSlide(ctx, direction),
+      infinite: ctx.props.infinite !== false,
+    };
+  };
+  const subscribe = <T extends AutoplayEventType>(
+    type: T,
+    listener: AutoplayEventListener<T>
+  ): (() => void) => {
+    const ctx = getCtx();
+    const set = getListenerSet(ctx, type);
+    set.add(listener);
+    return () => set.delete(listener);
+  };
+  const initVisibility = (): void => {
+    if (visibilityCleanup) return;
+    const ctx = getCtx();
+    if (ctx.props.pauseOnVisibilityChange === false) return;
+    visibilityCleanup = attachVisibilityObserver(
+      () => {
+        const c = getCtx();
+        wasScheduledBeforeHidden = c.autoplayState === 'scheduled';
+        if (wasScheduledBeforeHidden) {
+          cancel();
+          transitionState(c, 'idle');
+        }
+      },
+      () => {
+        if (wasScheduledBeforeHidden) {
+          wasScheduledBeforeHidden = false;
+          schedule();
+        }
+      }
+    );
+  };
+  const dispose = (): void => {
+    cancel();
+    const ctx = getCtx();
+    transitionState(ctx, 'idle');
+    ctx.autoplayListeners.clear();
+    if (visibilityCleanup) {
+      visibilityCleanup();
+      visibilityCleanup = null;
+    }
+  };
+  initVisibility();
+  return {
+    schedule,
+    cancel,
+    play,
+    pause,
+    getState,
+    getEffectiveDuration: getEffectiveDurationFn,
+    getDirection: getDirectionFn,
+    isAtTerminal: isAtTerminalFn,
+    computeNext,
+    getProgress,
+    subscribe,
+    dispose,
+  };
+}
