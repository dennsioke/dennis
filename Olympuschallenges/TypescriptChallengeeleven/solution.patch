index 0000000..29656c1
--- /dev/null
+++ b/src/utils/toolResultsCache.ts
@@ -0,0 +1,245 @@
+/**
+ * In-memory LRU cache for MCP tool results with TTL expiry and normalized fingerprinting.
+ *
+ * Uses JavaScript Map's insertion-order guarantee to implement O(1) amortized LRU:
+ * the first key in the Map is always the least-recently-used, and a key moves to the
+ * end on every access via delete + re-insert.  Expired entries are cleaned lazily on
+ * access and eagerly during eviction scans so the Map stays compact over time.
+ */
+
+export interface CacheOptions {
+  maxEntries: number;
+  ttlMs: number;
+  clock?: () => number;
+}
+
+export interface CacheStats {
+  size: number;
+  hits: number;
+  misses: number;
+  storeSize: number;
+}
+
+interface CacheEntry<T = unknown> {
+  value: T;
+  setAt: number;
+}
+
+export class ToolResultsCache<T = unknown> {
+  private readonly maxEntries: number;
+  private readonly ttlMs: number;
+  private readonly clock: () => number;
+  private readonly store = new Map<string, CacheEntry<T>>();
+  private _hits = 0;
+  private _misses = 0;
+
+  constructor({ maxEntries, ttlMs, clock }: CacheOptions) {
+    this.maxEntries = maxEntries;
+    this.ttlMs = ttlMs;
+    this.clock = clock ?? Date.now;
+  }
+
+  /**
+   * Returns the count of non-expired entries.  Expired entries remain in the store
+   * until touched; they are excluded from the reported size.
+   */
+  get size(): number {
+    const now = this.clock();
+    let count = 0;
+    for (const entry of this.store.values()) {
+      if (now - entry.setAt <= this.ttlMs) {
+        count++;
+      }
+    }
+    return count;
+  }
+
+  get hits(): number {
+    return this._hits;
+  }
+
+  get misses(): number {
+    return this._misses;
+  }
+
+  /**
+   * Returns a snapshot of cache statistics including the raw store size (which may
+   * include not-yet-pruned expired entries) alongside the live-entry count.
+   */
+  stats(): CacheStats {
+    return {
+      size: this.size,
+      hits: this._hits,
+      misses: this._misses,
+      storeSize: this.store.size,
+    };
+  }
+
+  /**
+   * Returns true when a non-expired entry exists for the given key without updating
+   * access recency or hit/miss counters.
+   */
+  has(toolName: string, params: Record<string, unknown>): boolean {
+    const key = this.buildKey(toolName, params);
+    const entry = this.store.get(key);
+    if (!entry) return false;
+    return this.clock() - entry.setAt <= this.ttlMs;
+  }
+
+  /**
+   * Retrieves a cached value.  Returns null on a miss or when the entry has expired.
+   * On a hit the entry is promoted to the most-recently-used position.
+   * An expired entry is removed from the store as a lazy-cleanup side effect.
+   */
+  get(toolName: string, params: Record<string, unknown>): T | null {
+    const key = this.buildKey(toolName, params);
+    const entry = this.store.get(key);
+
+    if (!entry) {
+      this._misses++;
+      return null;
+    }
+
+    if (this.clock() - entry.setAt > this.ttlMs) {
+      this.store.delete(key);
+      this._misses++;
+      return null;
+    }
+
+    // Promote to MRU: remove then re-append so this key is last in Map iteration order
+    this.store.delete(key);
+    this.store.set(key, entry);
+    this._hits++;
+    return entry.value;
+  }
+
+  /**
+   * Stores a value.  If an identical live entry already exists its TTL is reset and
+   * it is promoted to MRU (no eviction needed).  When inserting a genuinely new live
+   * entry that would bring live count above maxEntries, the LRU live entry is evicted
+   * first; any expired entries encountered during that scan are also removed.
+   */
+  set(toolName: string, params: Record<string, unknown>, value: T): void {
+    const key = this.buildKey(toolName, params);
+    const existing = this.store.get(key);
+    const now = this.clock();
+
+    const isLiveReplacement =
+      existing !== undefined && now - existing.setAt <= this.ttlMs;
+
+    // Remove any existing entry (expired or live) to reset LRU position
+    this.store.delete(key);
+
+    // Evict only when adding a new live entry and already at capacity
+    if (!isLiveReplacement && this.size >= this.maxEntries) {
+      for (const [k, e] of this.store) {
+        this.store.delete(k);
+        if (now - e.setAt <= this.ttlMs) {
+          // Found and evicted the LRU live entry - stop
+          break;
+        }
+        // Expired entry cleaned up; keep scanning for the LRU live entry
+      }
+    }
+
+    this.store.set(key, { value, setAt: now });
+  }
+
+  /**
+   * Removes cache entries.
+   * - When toolName is provided, only entries whose key starts with that tool prefix
+   *   are removed; other tools' entries are untouched.
+   * - When called with no argument, the entire store is cleared.
+   */
+  invalidate(toolName?: string): void {
+    if (toolName === undefined) {
+      this.store.clear();
+      return;
+    }
+    const prefix = `${toolName}:`;
+    for (const key of [...this.store.keys()]) {
+      if (key.startsWith(prefix)) {
+        this.store.delete(key);
+      }
+    }
+  }
+
+  /**
+   * Eagerly removes all expired entries from the store.  Calling this periodically
+   * keeps memory bounded without waiting for natural access-driven lazy cleanup.
+   * Returns the number of entries pruned.
+   */
+  prune(): number {
+    const now = this.clock();
+    let pruned = 0;
+    for (const [key, entry] of this.store) {
+      if (now - entry.setAt > this.ttlMs) {
+        this.store.delete(key);
+        pruned++;
+      }
+    }
+    return pruned;
+  }
+
+  /**
+   * Returns the cached value if present and fresh, otherwise calls fetcher, stores
+   * the result, and returns it.  This is a convenience wrapper around get + set that
+   * avoids the caller needing to check for null explicitly.
+   */
+  async getOrSet(
+    toolName: string,
+    params: Record<string, unknown>,
+    fetcher: () => Promise<T>
+  ): Promise<T> {
+    const cached = this.get(toolName, params);
+    if (cached !== null) {
+      return cached;
+    }
+    const fresh = await fetcher();
+    this.set(toolName, params, fresh);
+    return fresh;
+  }
+
+  /**
+   * Builds the canonical lookup key: "<toolName>:<normalized-params>".
+   */
+  private buildKey(toolName: string, params: Record<string, unknown>): string {
+    return `${toolName}:${this.normalizeValue(params)}`;
+  }
+
+  /**
+   * Recursively normalizes a value to a stable, canonical string representation:
+   *   - string  -> trimmed, lowercased, JSON-quoted
+   *   - number | boolean -> String(value)
+   *   - array   -> elements individually normalized then sorted, bracket-wrapped
+   *   - object  -> entries with non-null/undefined values, keys sorted, brace-wrapped
+   *   - null | undefined -> "\0" (omitted at object-entry level via the filter above)
+   *
+   * Key insertion order and redundant whitespace in string values are both ignored so
+   * that logically equivalent param objects always map to the same cache key.
+   */
+  private normalizeValue(val: unknown): string {
+    if (val === null || val === undefined) {
+      return "\0";
+    }
+    if (typeof val === "string") {
+      return JSON.stringify(val.trim().toLowerCase());
+    }
+    if (typeof val === "number" || typeof val === "boolean") {
+      return String(val);
+    }
+    if (Array.isArray(val)) {
+      const items = val.map((v) => this.normalizeValue(v)).sort();
+      return `[${items.join(",")}]`;
+    }
+    if (typeof val === "object") {
+      const rec = val as Record<string, unknown>;
+      const pairs = Object.entries(rec)
+        .filter(([, v]) => v !== null && v !== undefined)
+        .sort(([a], [b]) => (a < b ? -1 : a > b ? 1 : 0))
+        .map(([k, v]) => `${k}:${this.normalizeValue(v)}`);
+      return `{${pairs.join(",")}}`;
+    }
+    return String(val);
+  }
+}
