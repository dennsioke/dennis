diff --git a/src/core/resolver-cache.ts b/src/core/resolver-cache.ts
new file mode 100644
index 0000000..944a662
--- /dev/null
+++ b/src/core/resolver-cache.ts
@@ -0,0 +1,89 @@
+import type { ComponentInfo } from '../types'
+
+interface LRUNode {
+  key: string
+  value: ComponentInfo
+  prev: LRUNode | null
+  next: LRUNode | null
+}
+
+export class ResolverLRUCache {
+  private readonly maxSize: number
+  private readonly map: Map<string, LRUNode>
+  private readonly head: LRUNode
+  private readonly tail: LRUNode
+
+  constructor(maxSize: number) {
+    this.maxSize = maxSize
+    this.map = new Map()
+    this.head = { key: '', value: {} as ComponentInfo, prev: null, next: null }
+    this.tail = { key: '', value: {} as ComponentInfo, prev: null, next: null }
+    this.head.next = this.tail
+    this.tail.prev = this.head
+  }
+
+  get(key: string): ComponentInfo | undefined {
+    const node = this.map.get(key)
+    if (node === undefined)
+      return undefined
+    this.moveToFront(node)
+    return node.value
+  }
+
+  set(key: string, value: ComponentInfo): void {
+    const existing = this.map.get(key)
+    if (existing !== undefined) {
+      existing.value = value
+      this.moveToFront(existing)
+      return
+    }
+    const node: LRUNode = { key, value, prev: null, next: null }
+    this.map.set(key, node)
+    this.insertAtFront(node)
+    if (this.map.size > this.maxSize)
+      this.evictLast()
+  }
+
+  delete(key: string): void {
+    const node = this.map.get(key)
+    if (node === undefined)
+      return
+    this.removeNode(node)
+    this.map.delete(key)
+  }
+
+  clear(): void {
+    this.map.clear()
+    this.head.next = this.tail
+    this.tail.prev = this.head
+  }
+
+  get size(): number {
+    return this.map.size
+  }
+
+  private insertAtFront(node: LRUNode): void {
+    node.prev = this.head
+    node.next = this.head.next
+    this.head.next!.prev = node
+    this.head.next = node
+  }
+
+  private removeNode(node: LRUNode): void {
+    node.prev!.next = node.next
+    node.next!.prev = node.prev
+  }
+
+  private moveToFront(node: LRUNode): void {
+    this.removeNode(node)
+    this.insertAtFront(node)
+  }
+
+  private evictLast(): void {
+    const lru = this.tail.prev
+    if (lru === null || lru === this.head)
+      return
+    this.removeNode(lru)
+    this.map.delete(lru.key)
+  }
+}
